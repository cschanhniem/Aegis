{
  "name": "@agentguard/gateway-mcp",
  "version": "1.0.0",
  "description": "MCP Proxy Gateway for AgentGuard",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "pretest": "npm --workspace @agentguard/core-schema run build",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "calibrate": "tsc && node scripts/calibrate.mjs"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false
          }
        }
      ]
    }
  },
  "dependencies": {
    "@agentguard/core-schema": "file:../core-schema",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ajv": "^8.12.0",
    "better-sqlite3": "^9.0.0",
    "express": "^4.18.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
