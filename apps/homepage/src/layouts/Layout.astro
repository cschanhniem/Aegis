---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Aojie Yuan — Justin',
  description = 'M.S. student at USC. AI agent security, runtime guardrails, behavioral anomaly detection.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Aojie Yuan — Writing"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Tiempos / Söhne are Anthropic's licensed fonts. Closest free
      approximations on Google Fonts:
        - Instrument Serif → Tiempos Headline (headings)
        - Inter            → Söhne (body, ui)
        - JetBrains Mono   → Söhne Mono (code)
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        /* Claude-like warm cream palette (light) */
        --bg: #f0eee6;
        --surface: #f7f5ee;
        --text: #1f1e1b;
        --muted: #6f6b62;
        --hairline: rgba(31, 30, 27, 0.12);
        --accent: #c96442; /* Anthropic-ish warm clay */
        --link: #1f1e1b;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          /* Warm-dark, low-contrast — matches Anthropic dark mode */
          --bg: #1c1b18;
          --surface: #242320;
          --text: #ebe9e2;
          --muted: #98948a;
          --hairline: rgba(235, 233, 226, 0.12);
          --accent: #e08c6c;
          --link: #ebe9e2;
          color-scheme: dark;
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          system-ui,
          sans-serif;
        font-weight: 400;
        background: var(--bg);
        color: var(--text);
        line-height: 1.62;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings:
          'kern' 1,
          'liga' 1,
          'calt' 1;
      }

      body {
        margin: 0;
      }

      /* Serif for headings & display copy — Tiempos-like */
      h1,
      h2,
      h3,
      .serif {
        font-family:
          'Instrument Serif',
          'Tiempos Headline',
          'Source Serif Pro',
          ui-serif,
          Georgia,
          serif;
        font-weight: 400;
        letter-spacing: -0.005em;
        line-height: 1.15;
        color: var(--text);
      }

      code,
      pre,
      kbd {
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
        font-size: 0.86em;
      }

      a {
        color: var(--link);
        text-decoration: none;
        border-bottom: 1px solid var(--hairline);
        padding-bottom: 0.5px;
        transition: border-color 120ms ease;
      }
      a:hover {
        border-bottom-color: var(--text);
      }

      ::selection {
        background: rgba(201, 100, 66, 0.22);
      }

      @media (prefers-color-scheme: dark) {
        ::selection {
          background: rgba(224, 140, 108, 0.28);
        }
      }

      hr {
        border: 0;
        border-top: 1px solid var(--hairline);
        margin: 4rem 0;
      }
    </style>
  </body>
</html>
