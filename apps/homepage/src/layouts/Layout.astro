---
interface Props {
  title?: string;
  description?: string;
  /** Optional override for og:image (absolute or root-relative). */
  ogImage?: string;
}
const {
  title = 'Aojie Yuan — Justin',
  description = 'Building AEGIS — an open-source pre-execution firewall and audit layer for AI agents.',
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://aojieyuan.com';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Aojie Yuan — Writing"
      href="/rss.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Tiempos / Söhne are Anthropic's licensed fonts. Closest free
      approximations on Google Fonts:
        - Instrument Serif → Tiempos Headline (headings)
        - Inter            → Söhne (body, ui)
        - JetBrains Mono   → Söhne Mono (code)
    -->
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <!-- Canonical + theme -->
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#eae3d2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1816" media="(prefers-color-scheme: dark)" />
    <meta name="author" content="Aojie Yuan" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Aojie Yuan" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The runtime safety layer for tool-using AI agents — Aojie Yuan / AEGIS" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        /* Beige + black — paper-and-ink aesthetic. CTAs are black-on-beige. */
        --bg: #eae3d2;
        --surface: #f2edd8;
        --text: #0a0a0a;
        --muted: #5c5a50;
        --hairline: rgba(10, 10, 10, 0.10);
        --accent: #0a0a0a;
        --link: #0a0a0a;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          /* Inverted: deep ink ground, beige type */
          --bg: #1a1816;
          --surface: #242220;
          --text: #eae3d2;
          --muted: #9a968b;
          --hairline: rgba(234, 227, 210, 0.10);
          --accent: #eae3d2;
          --link: #eae3d2;
          color-scheme: dark;
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          system-ui,
          sans-serif;
        font-weight: 400;
        background: var(--bg);
        color: var(--text);
        line-height: 1.62;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings:
          'kern' 1,
          'liga' 1,
          'calt' 1;
      }

      body {
        margin: 0;
      }

      /* Serif for headings & display copy — Tiempos-like */
      h1,
      h2,
      h3,
      .serif {
        font-family:
          'Instrument Serif',
          'Tiempos Headline',
          'Source Serif Pro',
          ui-serif,
          Georgia,
          serif;
        font-weight: 400;
        letter-spacing: -0.005em;
        line-height: 1.15;
        color: var(--text);
      }

      code,
      pre,
      kbd {
        font-family: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
        font-size: 0.86em;
      }

      a {
        color: var(--link);
        text-decoration: none;
        border-bottom: 1px solid var(--hairline);
        padding-bottom: 0.5px;
        transition: border-color 120ms ease;
      }
      a:hover {
        border-bottom-color: var(--text);
      }

      ::selection {
        background: rgba(10, 10, 10, 0.12);
      }

      @media (prefers-color-scheme: dark) {
        ::selection {
          background: rgba(234, 227, 210, 0.18);
        }
      }

      hr {
        border: 0;
        border-top: 1px solid var(--hairline);
        margin: 4rem 0;
      }
    </style>
  </body>
</html>
