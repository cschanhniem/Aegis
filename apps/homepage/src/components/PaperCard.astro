---
interface Props {
  title: string;
  venue: string;
  arxivId: string;
  abstract: string;
  authors?: string;
  badge?: string;
}
const { title, venue, arxivId, abstract, authors, badge } = Astro.props;
---

<article class="paper">
  <div class="meta">
    <span class="venue">{venue}</span>
    {badge && <span class="badge">{badge}</span>}
  </div>
  <h3>{title}</h3>
  {authors && <p class="authors">{authors}</p>}
  <p class="abstract">{abstract}</p>
  <div class="links">
    <a href={`https://arxiv.org/abs/${arxivId}`} target="_blank" rel="noopener">arXiv:{arxivId}</a>
    <a href={`https://arxiv.org/pdf/${arxivId}`} target="_blank" rel="noopener">PDF</a>
  </div>
</article>

<style>
  .paper {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.4rem;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .paper:hover {
    border-color: var(--accent-soft);
  }
  .meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 0.55rem;
  }
  .venue {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 600;
  }
  .badge {
    font-size: 0.66rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: hsl(38 24% 88%);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }
  h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    line-height: 1.35;
    color: var(--text);
  }
  .authors {
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0 0 0.7rem;
  }
  .abstract {
    font-size: 0.88rem;
    color: var(--text);
    margin: 0 0 0.85rem;
    opacity: 0.85;
  }
  .links {
    display: flex;
    gap: 1rem;
    font-size: 0.82rem;
  }
</style>
