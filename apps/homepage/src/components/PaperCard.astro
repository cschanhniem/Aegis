---
interface Props {
  title: string;
  venue: string;
  arxivId: string;
  abstract: string;
  authors?: string;
  badge?: string;
}
const { title, venue, arxivId, abstract, authors, badge } = Astro.props;
---

<article class="paper">
  <div class="meta">
    <span class="venue">{venue}</span>
    {badge && <span class="badge">{badge}</span>}
  </div>
  <h3>{title}</h3>
  {authors && <p class="authors">{authors}</p>}
  <p class="abstract">{abstract}</p>
  <div class="links">
    <a href={`https://arxiv.org/abs/${arxivId}`} target="_blank" rel="noopener">arXiv:{arxivId}</a>
    <span class="dot">·</span>
    <a href={`https://arxiv.org/pdf/${arxivId}`} target="_blank" rel="noopener">PDF</a>
  </div>
</article>

<style>
  .paper {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--hairline);
  }
  .paper:last-child {
    border-bottom: 0;
  }
  .meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .venue {
    font-size: 0.74rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }
  .badge {
    font-size: 0.66rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  h3 {
    font-size: 1.5rem;
    line-height: 1.25;
    margin: 0 0 0.35rem;
  }
  .authors {
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0 0 0.85rem;
    font-style: italic;
  }
  .abstract {
    font-size: 0.97rem;
    color: var(--text);
    margin: 0 0 1rem;
    opacity: 0.84;
    line-height: 1.6;
  }
  .links {
    font-size: 0.84rem;
    color: var(--muted);
  }
  .links a {
    color: var(--muted);
  }
  .links a:hover {
    color: var(--text);
    border-bottom-color: var(--text);
  }
  .dot {
    margin: 0 0.45rem;
    opacity: 0.5;
  }
</style>
