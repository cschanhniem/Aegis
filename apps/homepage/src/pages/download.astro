---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';

const LATEST_TAG = 'v0.1.0';
const MAC_ARM_URL =
  `https://github.com/Justin0504/Aegis/releases/download/${LATEST_TAG}/AEGIS_0.1.0_aarch64.dmg`;
---

<Layout
  title="Download AEGIS"
  description="Download AEGIS — the open-source runtime safety layer for AI agents. macOS Apple Silicon ready; Intel, Windows, and Linux coming in v0.2."
>
  <main>
    <Header />

    <section class="head">
      <p class="eyebrow">Download AEGIS</p>
      <h1>
        One file. Double-click. <em>Done.</em>
      </h1>
      <p class="lede">
        No Docker, no <code>npm install</code>, no shell paste. The
        installer ships the gateway, the cockpit, and a portable
        Node runtime — protection is on the second you launch the app.
      </p>
    </section>

    <!-- Auto-detected primary card -->
    <section class="primary" id="primary-slot"></section>

    <!-- Full platform grid -->
    <section class="grid">
      <article class="card" data-platform="mac-arm">
        <header>
          <h2>macOS · Apple Silicon</h2>
          <span class="state ok">v0.1.0 · available</span>
        </header>
        <p>For M1, M2, M3, M4 Macs. 164 MB DMG.</p>
        <a class="cta" href={MAC_ARM_URL}>Download .dmg →</a>
        <p class="hint">
          Unsigned for now — first launch shows a Gatekeeper warning.
          Right-click <strong>AEGIS</strong> → <strong>Open</strong> →
          <strong>Open</strong>. Code-signed build lands in v0.2.
        </p>
      </article>

      <article class="card" data-platform="mac-intel">
        <header>
          <h2>macOS · Intel</h2>
          <span class="state soon">v0.2 · coming</span>
        </header>
        <p>x86_64 build is on the v0.2 milestone — needs a separate
          CI runner since Apple Silicon Macs can't cross-compile native
          Node modules to Intel without help.</p>
        <a
          class="cta-secondary"
          href="https://github.com/Justin0504/Aegis/issues/new?title=Intel%20macOS%20build"
        >
          Subscribe to this issue
        </a>
      </article>

      <article class="card" data-platform="windows">
        <header>
          <h2>Windows · x64</h2>
          <span class="state soon">v0.2 · coming</span>
        </header>
        <p>MSI installer via GitHub Actions on
          <code>windows-latest</code>. CI scaffold is in place; the
          gateway's better-sqlite3 native module needs Windows-specific
          packaging before the first .exe ships.</p>
        <a
          class="cta-secondary"
          href="https://github.com/Justin0504/Aegis/issues/new?title=Windows%20build"
        >
          Subscribe to this issue
        </a>
      </article>

      <article class="card" data-platform="linux">
        <header>
          <h2>Linux · x64 / arm64</h2>
          <span class="state diy">build from source</span>
        </header>
        <p>Run the install script — it pulls the repo, runs
          <code>docker compose up -d</code>, and hands you the gateway
          + Cockpit on localhost.</p>
        <pre><code>curl -fsSL https://raw.githubusercontent.com/Justin0504/Aegis/main/scripts/install.sh | bash</code></pre>
        <p class="hint">
          A native .AppImage is on the v0.2+ roadmap.
        </p>
      </article>
    </section>

    <section class="below">
      <h3>What you get</h3>
      <ul>
        <li><strong>Embedded gateway + cockpit</strong> bound to
          <code>127.0.0.1:18080 / :13001</code> — won't conflict with a
          parallel Docker install.</li>
        <li><strong>14 framework SDKs</strong> auto-instrument on
          import. Two lines in your agent.</li>
        <li><strong>Live process scanner</strong> — the menu-bar icon
          shows a red dot the moment AEGIS spots a running Python or
          Node process using <code>anthropic</code> /
          <code>openai</code> / <code>langchain</code> that isn't yet
          routed through it.</li>
        <li><strong>Per-tenant Policy DSL</strong> with fail-safe
          semantics — defaults are never relaxed.</li>
        <li><strong>Compliance Cockpit</strong>: traces, approvals,
          tenant config, deployment templates.</li>
        <li><strong>MIT licensed</strong>. Self-host the gateway,
          ship it inside your enterprise, fork it — anything.</li>
      </ul>
    </section>

    <p class="footer-note">
      Newer versions land at
      <a
        href="https://github.com/Justin0504/Aegis/releases/latest"
        target="_blank"
        rel="noopener"
      >github.com/Justin0504/Aegis/releases/latest</a>.
    </p>
  </main>

  <style>
    main {
      max-width: 720px;
      margin: 0 auto;
      padding: 1.5rem 1.75rem 6rem;
    }
    .head { margin: 4rem 0 2rem; }
    .eyebrow {
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.13em;
      margin: 0 0 0.7rem;
      font-weight: 500;
    }
    .head h1 {
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      line-height: 1.12;
      margin: 0 0 1.1rem;
      letter-spacing: -0.014em;
    }
    .head h1 em { font-style: italic; }
    .lede {
      font-size: 1.05rem;
      color: var(--text);
      opacity: 0.84;
      max-width: 48ch;
      margin: 0;
    }

    .primary {
      margin: 1.5rem 0 2.5rem;
      min-height: 0;
    }
    .primary .recommend {
      padding: 1.4rem 1.5rem;
      border: 2px solid var(--text);
      border-radius: 8px;
      display: flex;
      align-items: center;
      gap: 1rem;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .primary .recommend .info { min-width: 0; }
    .primary .recommend .info strong {
      font-family: var(--serif), Georgia, serif;
      font-size: 1.25rem;
      letter-spacing: -0.005em;
    }
    .primary .recommend .info p {
      margin: 0.25rem 0 0;
      font-size: 0.86rem;
      color: var(--muted);
    }
    .primary .recommend a {
      font-size: 0.95rem;
      padding: 0.55rem 1.1rem;
      background: var(--text);
      color: var(--bg);
      border-radius: 4px;
      text-decoration: none;
      border: 0;
      white-space: nowrap;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @media (max-width: 640px) {
      .grid { grid-template-columns: 1fr; }
    }

    .card {
      padding: 1.3rem 1.4rem;
      border: 1px solid var(--hairline);
      border-radius: 8px;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }
    .card header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.8rem;
    }
    .card h2 {
      font-size: 1.05rem;
      margin: 0;
      font-weight: 600;
      letter-spacing: -0.005em;
      font-family: inherit;
    }
    .state {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      white-space: nowrap;
    }
    .state.ok   { color: hsl(150 22% 32%); }
    .state.soon { color: hsl(36 60% 32%); }
    .state.diy  { color: var(--muted); }

    .card p {
      margin: 0;
      font-size: 0.88rem;
      color: var(--text);
      opacity: 0.85;
      line-height: 1.55;
    }
    .card .hint {
      font-size: 0.76rem;
      color: var(--muted);
      opacity: 1;
    }
    .card pre {
      margin: 0;
      padding: 0.65rem 0.85rem;
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 4px;
      overflow-x: auto;
      font-size: 0.72rem;
      line-height: 1.5;
      white-space: nowrap;
    }

    .card .cta {
      align-self: flex-start;
      font-size: 0.9rem;
      padding: 0.5rem 0.9rem;
      background: var(--text);
      color: var(--bg);
      border-radius: 4px;
      text-decoration: none;
    }
    .card .cta-secondary {
      align-self: flex-start;
      font-size: 0.85rem;
      color: var(--muted);
      border-bottom: 1px solid var(--hairline);
    }
    .card .cta-secondary:hover {
      color: var(--text);
      border-bottom-color: var(--text);
    }

    .below {
      margin-top: 3rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--hairline);
    }
    .below h3 {
      font-size: 1.5rem;
      margin: 0 0 1rem;
      line-height: 1.2;
    }
    .below ul {
      padding-left: 1.2rem;
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.7;
    }
    .below li { margin-bottom: 0.45rem; }
    .footer-note {
      margin-top: 2.5rem;
      font-size: 0.85rem;
      color: var(--muted);
    }
  </style>

  <script is:inline define:vars={{ MAC_ARM_URL }}>
    // Highlight whichever card matches the visitor's platform.
    // Pure progressive enhancement — the page works fine without JS.
    (function () {
      const ua = navigator.userAgent || '';
      const platform = navigator.platform || '';
      const isMac = /Mac|iPad|iPhone|iPod/.test(platform) || /Mac/i.test(ua);
      const isWin = /Win/i.test(platform) || /Windows/i.test(ua);
      const isLinux = /Linux/i.test(platform) && !/Android/i.test(ua);

      let match;
      let pickLabel;
      let downloadHref;
      let available = false;
      if (isMac) {
        // Best-effort: if user is on Apple Silicon, navigator.userAgent
        // contains "Macintosh; Intel" on both archs (Apple hides this
        // intentionally). We pick the only build we ship and tell them.
        match = 'mac-arm';
        pickLabel = 'We think you\'re on macOS · Apple Silicon';
        downloadHref = MAC_ARM_URL;
        available = true;
      } else if (isWin) {
        match = 'windows';
        pickLabel = 'We think you\'re on Windows';
      } else if (isLinux) {
        match = 'linux';
        pickLabel = 'We think you\'re on Linux';
      }

      if (!match) return;
      const slot = document.getElementById('primary-slot');
      if (!slot) return;

      const card = document.createElement('div');
      card.className = 'recommend';
      const info = document.createElement('div');
      info.className = 'info';
      const heading = document.createElement('strong');
      heading.textContent = pickLabel;
      const sub = document.createElement('p');
      sub.textContent = available
        ? 'Click below to grab the build that matches.'
        : 'Pick another platform below or subscribe to the issue.';
      info.appendChild(heading);
      info.appendChild(sub);
      card.appendChild(info);

      if (available && downloadHref) {
        const a = document.createElement('a');
        a.href = downloadHref;
        a.textContent = 'Download for ' + (match === 'mac-arm' ? 'macOS (Apple Silicon)' : '');
        card.appendChild(a);
      } else {
        const a = document.createElement('a');
        a.href = '#';
        a.textContent = 'See options below';
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.querySelector('.card[data-platform="' + match + '"]');
          target && target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
        card.appendChild(a);
      }

      slot.innerHTML = '';
      slot.appendChild(card);
    })();
  </script>
</Layout>
