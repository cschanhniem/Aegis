---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import { sortedPosts as posts } from '@/data/posts';
---

<Layout>
  <main>
    <Header current="home" />

    <!-- Hero -->
    <section class="hero">
      <p class="eyebrow">Aojie Yuan · Justin</p>
      <h1>
        I work on the runtime <em>safety layer</em> for tool-using AI agents.
      </h1>
      <p class="lede">
        M.S. student at <a href="https://www.usc.edu" target="_blank" rel="noopener">USC</a>.
        Building AEGIS — an open-source pre-execution firewall that keeps a
        hallucinated <code>DROP&nbsp;TABLE</code> from ever reaching production.
      </p>
      <nav class="header-links">
        <a href="https://arxiv.org/a/yuan_a_3" target="_blank" rel="noopener">arXiv</a>
        <a href="mailto:aojieyua@usc.edu">aojieyua@usc.edu</a>
        <a href="/now">/now</a>
      </nav>
    </section>

    <hr />

    <!-- Featured project -->
    <section>
      <p class="section-eyebrow">Currently building</p>
      <h2>AEGIS</h2>
      <p class="section-lede">
        A pre-execution firewall and audit layer for AI agents. Every tool call
        is classified, run through a cost-aware L1/L2/L3 cascade
        <span class="muted">(rules → XGBoost → LLM-judge)</span>, and matched
        against a per-tenant Policy DSL with fail-safe semantics — all before
        execution, with zero changes to agent code.
      </p>

      <div class="stats">
        <div><span class="num">99.9%</span><span class="label">block rate</span></div>
        <div><span class="num">1.1<i>ms</i></span><span class="label">p50 latency</span></div>
        <div><span class="num">14</span><span class="label">frameworks</span></div>
        <div><span class="num">MIT</span><span class="label">licensed</span></div>
      </div>

      <div class="project-actions">
        <a class="cta" href="/download">
          Download →
        </a>
        <a class="cta-secondary" href="https://github.com/Justin0504/Aegis" target="_blank" rel="noopener">
          View on GitHub
        </a>
      </div>

      <details class="install-details">
        <summary>Or build from source / use Docker</summary>
        <pre class="install"><code>curl -fsSL https://raw.githubusercontent.com/Justin0504/Aegis/main/scripts/install.sh | bash</code></pre>
      </details>

      <figure class="flow" aria-label="AEGIS request flow">
        <div class="flow-row">
          <span class="node">your agent</span>
          <span class="arrow" aria-hidden="true">→</span>
          <span class="node group">
            <span class="stage">classify</span>
            <span class="stage">L1 rules</span>
            <span class="stage">L2 ML</span>
            <span class="stage">L3 judge</span>
            <span class="stage">DSL</span>
          </span>
          <span class="arrow" aria-hidden="true">→</span>
          <span class="node">tool</span>
        </div>
        <figcaption>
          Every call: classified, cascaded, matched against tenant DSL — decisions
          are <span class="d-allow">allow</span> ·
          <span class="d-pending">pending</span> ·
          <span class="d-block">block</span>. Defaults can be tightened, never relaxed.
        </figcaption>
      </figure>
      <div class="recently-shipped">
        <p class="section-eyebrow inline">Recently shipped on main</p>
        <ul class="shipped-list">
          <li>
            <strong>Agent identity + registration</strong> — registered
            agents have status / declared tool scope / per-agent budget /
            optional shared secret. The SDK forwards
            <code>X-AEGIS-Agent-Secret</code> automatically; the gateway
            blocks suspended or unregistered agents at the gate.
          </li>
          <li>
            <strong>AEGIS Agent Threat Ontology v1</strong> — 10 tactics
            × 40 techniques (<code>AAT-T*</code>) published with per-
            deployment coverage map. The Cockpit
            <code>/coverage</code> page renders it as a heat-map; the
            REST API at <code>/api/v1/ontology/coverage</code> is what
            customers compare AEGIS against other vendors with.
          </li>
          <li>
            <strong>LLM egress proxy</strong> — customer sets
            <code>OPENAI_BASE_URL=…aegis…/openai/v1</code> and every
            LLM call from any language / any framework / any closed-
            source platform now flows through the detector chain,
            audit, transparency log, and SIEM sinks.
          </li>
          <li>
            <strong>Universal SIEM sinks + OTLP trace export</strong> —
            declarative <code>http</code> / <code>syslog</code> sinks
            for Splunk / Datadog / QRadar; per-tenant OTLP exporter
            ships spans to Honeycomb / Grafana Tempo / New Relic. Both
            configurable via tenant config, no fork required.
          </li>
          <li>
            <strong>RFC 6962 transparency log</strong> — every audit row
            and compliance bundle appends to an append-only Merkle log
            with Ed25519-signed roots. Customers can verify any past
            event's existence offline against a cached signed root.
          </li>
          <li>
            <strong>Signed per-framework compliance bundles</strong> —
            <code>POST /api/v1/compliance/bundle/&lt;soc2|iso27001|nist-ai-rmf|eu-ai-act&gt;</code>
            returns a signed JSON artifact mapping each control to live
            AEGIS evidence. The auditor verifies; you don't argue.
          </li>
          <li>
            <strong>Detector plugin contract + threat detectors for the
            new red zones</strong> — IPI (T1001), memory-poison
            (T6001), discovery / credential discovery (T7001-T7003),
            cross-agent trust abuse (T10001), session/token replay
            (T10002), sensitive-context exfiltration (T5001) all
            shipped behind the same pluggable Detector interface.
          </li>
          <li>
            <strong>Ed25519-signed releases</strong> — every npm tarball
            and PyPI wheel ships with a verifiable signature manifest;
            pin trust on
            <code>.well-known/aegis-release-pubkey.pem</code> once.
          </li>
        </ul>
        <p class="section-foot">
          See the full <a href="https://github.com/Justin0504/Aegis/blob/main/ROADMAP.md">roadmap</a>
          and <a href="https://github.com/Justin0504/Aegis/blob/main/CHANGELOG.md">changelog</a>.
        </p>
      </div>
    </section>

    <hr />

    <!-- Writing -->
    <section>
      <p class="section-eyebrow">Writing</p>
      <h2>Recent posts</h2>

      <ul class="post-list">
        {
          posts.slice(0, 3).map((p) => (
            <li>
              <a href={`/writing/${p.slug}`} class="post-link">
                <time datetime={p.date}>
                  {new Date(p.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                <span class="post-title">{p.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="see-all">
        <a href="/writing">See all writing →</a>
      </p>
    </section>

    <hr />

    <!-- Footer -->
    <footer>
      <p>
        Currently in Los Angeles · happy to talk agent safety, LLM tooling, or
        the systems half of ML — <a href="mailto:aojieyua@usc.edu">drop me a line</a>.
      </p>
    </footer>
  </main>

  <style>
    main {
      max-width: 640px;
      margin: 0 auto;
      padding: 1.5rem 1.75rem 6rem;
    }
    .hero {
      margin-top: 5rem;
    }

    /* Hero ──────────────────────────────────────────── */
    .eyebrow {
      font-size: 0.85rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      margin: 0 0 1.5rem;
      font-weight: 500;
    }

    .hero h1 {
      font-size: clamp(2.3rem, 5.5vw, 3.6rem);
      line-height: 1.08;
      margin: 0 0 1.6rem;
      letter-spacing: -0.012em;
    }
    .hero h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .lede {
      font-size: 1.12rem;
      line-height: 1.6;
      color: var(--text);
      opacity: 0.84;
      margin: 0 0 2rem;
      max-width: 38ch;
    }

    .header-links {
      display: flex;
      gap: 1.6rem;
      font-size: 0.95rem;
      color: var(--muted);
    }
    .header-links a {
      color: var(--muted);
      border-bottom-color: transparent;
    }
    .header-links a:hover {
      color: var(--text);
      border-bottom-color: var(--text);
    }

    /* Section common ─────────────────────────────────── */
    .section-eyebrow {
      font-size: 0.74rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.13em;
      margin: 0 0 0.7rem;
      font-weight: 500;
    }
    .section-eyebrow.inline {
      margin: 0 0 0.4rem;
    }

    /* Recently shipped ───────────────────────────────── */
    .recently-shipped {
      margin: 2.4rem 0 0;
      padding: 1.4rem 1.6rem;
      border: 1px solid var(--hairline);
      border-radius: 4px;
      background: var(--surface, transparent);
    }
    .shipped-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .shipped-list li {
      font-size: 0.96rem;
      line-height: 1.55;
      color: var(--text);
    }
    .shipped-list strong {
      font-weight: 600;
    }
    .shipped-list code {
      font-family: var(--font-mono, ui-monospace, "SF Mono", monospace);
      font-size: 0.86em;
      color: var(--muted);
    }
    .section-foot {
      margin: 1.1rem 0 0;
      font-size: 0.86rem;
      color: var(--muted);
    }
    section h2 {
      font-size: 2.4rem;
      margin: 0 0 1.4rem;
    }
    .section-lede {
      font-size: 1.04rem;
      line-height: 1.6;
      margin: 0 0 2rem;
      max-width: 56ch;
    }
    .muted {
      color: var(--muted);
    }

    /* Project ────────────────────────────────────────── */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.6rem 1rem;
      margin: 0 0 2rem;
      padding: 1.4rem 0;
      border-top: 1px solid var(--hairline);
      border-bottom: 1px solid var(--hairline);
    }
    .stats > div {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .num {
      font-family:
        'Instrument Serif',
        ui-serif,
        Georgia,
        serif;
      font-size: 1.85rem;
      line-height: 1.05;
      color: var(--text);
    }
    .num i {
      font-style: italic;
      font-size: 0.65em;
      color: var(--muted);
      padding-left: 0.05em;
    }
    .label {
      font-size: 0.72rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .project-actions {
      display: flex;
      gap: 1.4rem;
      align-items: center;
      margin: 0 0 1.8rem;
      flex-wrap: wrap;
    }
    .cta {
      font-size: 0.96rem;
      color: var(--text);
      border-bottom: 1px solid var(--text);
      padding-bottom: 1px;
    }
    .cta:hover {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
    .cta-secondary {
      font-size: 0.96rem;
      color: var(--muted);
      border-bottom: 1px solid var(--hairline);
    }
    .cta-secondary:hover {
      color: var(--text);
      border-bottom-color: var(--text);
    }

    .install-details {
      margin-top: 0.4rem;
    }
    .install-details summary {
      font-size: 0.82rem;
      color: var(--muted);
      cursor: pointer;
      padding: 0.4rem 0;
      list-style: none;
    }
    .install-details summary::-webkit-details-marker { display: none; }
    .install-details summary::before {
      content: '▸ ';
      font-size: 0.7rem;
      opacity: 0.6;
      transition: transform 120ms ease;
      display: inline-block;
    }
    .install-details[open] summary::before { content: '▾ '; }
    .install-details summary:hover { color: var(--text); }
    .install {
      margin: 0.5rem 0 0;
      padding: 1rem 1.2rem;
      background: var(--surface);
      border: 1px solid var(--hairline);
      border-radius: 4px;
      overflow-x: auto;
      font-size: 0.78rem;
      line-height: 1.5;
      color: var(--text);
      white-space: nowrap;
    }
    .install code {
      font-size: inherit;
    }

    /* Flow diagram ───────────────────────────────────── */
    .flow {
      margin: 2rem 0 0;
      padding: 1.3rem 0 0;
      border-top: 1px solid var(--hairline);
    }
    .flow-row {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.82rem;
      color: var(--text);
    }
    .node {
      padding: 0.32rem 0.65rem;
      border: 1px solid var(--hairline);
      border-radius: 4px;
      background: var(--surface);
      white-space: nowrap;
    }
    .node.group {
      display: inline-flex;
      gap: 0.35rem;
      padding: 0.18rem 0.32rem;
    }
    .stage {
      padding: 0.12rem 0.45rem;
      background: var(--bg);
      border-radius: 3px;
      color: var(--muted);
      font-size: 0.76rem;
    }
    .arrow {
      color: var(--muted);
      opacity: 0.7;
      font-size: 0.92rem;
    }
    .flow figcaption {
      margin-top: 0.85rem;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.55;
    }
    /* Semantic decision colors — must stay distinguishable in mono palette */
    .d-allow { color: hsl(150 22% 32%); }    /* moss green */
    .d-pending { color: hsl(36 60% 32%); }   /* mustard amber */
    .d-block { color: hsl(0 50% 38%); }      /* oxblood */

    @media (max-width: 560px) {
      .flow-row {
        font-size: 0.74rem;
        gap: 0.5rem;
      }
      .stage {
        font-size: 0.7rem;
      }
    }

    /* Writing ────────────────────────────────────────── */
    .post-list {
      list-style: none;
      padding: 0;
      margin: 0 0 1.4rem;
    }
    .post-list li {
      border-top: 1px solid var(--hairline);
    }
    .post-list li:last-child {
      border-bottom: 1px solid var(--hairline);
    }
    .post-link {
      display: flex;
      gap: 1.2rem;
      align-items: baseline;
      padding: 1rem 0;
      border-bottom: 0;
      color: var(--text);
    }
    .post-link:hover .post-title {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 4px;
    }
    .post-link time {
      font-size: 0.78rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      min-width: 5rem;
      flex-shrink: 0;
    }
    .post-title {
      font-size: 1.02rem;
      transition: color 120ms ease;
    }
    .see-all {
      font-size: 0.92rem;
      color: var(--muted);
      margin: 0;
    }
    .see-all a {
      color: var(--muted);
      border-bottom-color: transparent;
    }
    .see-all a:hover {
      color: var(--text);
      border-bottom-color: var(--text);
    }

    /* Footer ─────────────────────────────────────────── */
    footer {
      font-size: 0.92rem;
      color: var(--muted);
      max-width: 50ch;
    }

    /* Responsive ─────────────────────────────────────── */
    @media (max-width: 560px) {
      main {
        padding: 4.5rem 1.4rem 4rem;
      }
      .stats {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.2rem;
      }
      section h2 {
        font-size: 2rem;
      }
    }
  </style>
</Layout>
