---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import incidentsRaw from '@/data/incidents.json';

interface Incident {
  id: string;            // YYYY-MM-DD-slug
  title: string;
  started_at: string;    // ISO 8601
  resolved_at?: string;  // ISO 8601 when resolved
  status: 'resolved' | 'monitoring' | 'investigating' | 'identified';
  components: string[];  // which surfaces affected
  body: string;          // markdown / plain
}

const incidents = incidentsRaw as Incident[];

// Current top-level status — anchored on whether any incident is open.
const openCount = incidents.filter((i) => i.status !== 'resolved').length;
const top: 'ok' | 'investigating' | 'down' =
  openCount === 0 ? 'ok' : openCount === 1 ? 'investigating' : 'down';

// "Operational since" anchor — first commit on main; manually updated when
// we have a real deployment with measurable uptime to point at.
const OPERATIONAL_SINCE = '2026-04-08';
const today = new Date();
const since = new Date(OPERATIONAL_SINCE);
const daysOperational = Math.max(
  0,
  Math.floor((today.getTime() - since.getTime()) / (1000 * 60 * 60 * 24)),
);

const components = [
  { name: 'Gateway API',           note: 'classify / check / blocking decisions' },
  { name: 'Cockpit Dashboard',     note: 'real-time monitoring + audit log + DSL editor' },
  { name: 'SDKs (Python, JS, Go)', note: 'agent instrumentation libraries' },
  { name: 'MCP servers',           note: 'WebSocket + stdio (Claude Desktop, mcp2cli)' },
  { name: 'Evidence pack export',  note: 'SOC 2 signed bundle + offline verify' },
];

function relative(s: string): string {
  const ms = today.getTime() - new Date(s).getTime();
  if (ms < 60_000) return `${Math.max(1, Math.floor(ms / 1000))}s ago`;
  if (ms < 3_600_000) return `${Math.floor(ms / 60_000)}m ago`;
  if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)}h ago`;
  return `${Math.floor(ms / 86_400_000)}d ago`;
}
---

<Layout>
  <main>
    <Header current="status" />

    <section class="hero">
      <p class="eyebrow">Status</p>
      <h1 class="status-h1" data-status={top}>
        {top === 'ok'
          ? 'All systems operational.'
          : top === 'investigating'
            ? 'One incident under investigation.'
            : `${openCount} incidents under investigation.`}
      </h1>
      <p class="lede">
        AEGIS is an open-source project — there is no SaaS to monitor.
        This page tracks the canonical reference deployment that backs
        the demo on this site and the responsiveness of the GitHub
        releases pipeline that ships the binaries you download.
      </p>
    </section>

    <hr />

    <!-- Component status grid -->
    <section>
      <p class="section-eyebrow">Components</p>
      <div class="grid">
        {components.map((c) => (
          <article class="card">
            <header>
              <h3>{c.name}</h3>
              <span class="dot dot-ok" title="operational"></span>
            </header>
            <p>{c.note}</p>
          </article>
        ))}
      </div>
      <p class="muted-fine">
        Component status is updated manually per release; we will swap
        to live health probes once the gateway runs at a publicly
        reachable URL.
      </p>
    </section>

    <hr />

    <!-- Uptime stat -->
    <section class="stats">
      <div>
        <span class="num">{daysOperational}</span>
        <span class="label">days operational</span>
      </div>
      <div>
        <span class="num">{incidents.length}</span>
        <span class="label">incidents recorded</span>
      </div>
      <div>
        <span class="num">{openCount}</span>
        <span class="label">currently open</span>
      </div>
    </section>

    <hr />

    <!-- Incident log -->
    <section>
      <p class="section-eyebrow">Incident log</p>
      {incidents.length === 0 ? (
        <p class="muted">No incidents recorded since {OPERATIONAL_SINCE}.</p>
      ) : (
        <ul class="incidents">
          {incidents.map((i) => (
            <li>
              <h3>{i.title}</h3>
              <p class="meta">
                <span class="badge badge-{i.status}">{i.status}</span>
                <span>started {relative(i.started_at)}</span>
                {i.resolved_at && <span>resolved {relative(i.resolved_at)}</span>}
                <span>· {i.components.join(', ')}</span>
              </p>
              <p>{i.body}</p>
            </li>
          ))}
        </ul>
      )}
      <p class="muted-fine">
        Subscribe via the <a href="/rss.xml">RSS feed</a> or watch the
        <a href="https://github.com/Justin0504/Aegis/issues?q=is%3Aissue+label%3Aincident">
          incident-labelled GitHub issues
        </a>.
      </p>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 4rem;
    font-family: var(--font-sans, ui-sans-serif, system-ui, sans-serif);
    color: var(--text);
  }

  /* Hero */
  .hero { margin: 1.6rem 0 1rem; }
  .eyebrow {
    font-size: 0.74rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    margin: 0 0 0.7rem;
    font-weight: 500;
  }
  .status-h1 {
    font-size: 2.4rem;
    line-height: 1.15;
    margin: 0 0 0.9rem;
    font-weight: 500;
    color: var(--text);
  }
  .status-h1[data-status="ok"]            { color: hsl(150 22% 32%); }
  .status-h1[data-status="investigating"] { color: hsl(36 60% 32%);  }
  .status-h1[data-status="down"]          { color: hsl(0 50% 38%);   }
  .lede {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    max-width: 56ch;
  }

  hr { border: none; border-top: 1px solid var(--hairline); margin: 2.4rem 0; }

  /* Section common */
  .section-eyebrow {
    font-size: 0.74rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.13em;
    margin: 0 0 0.9rem;
    font-weight: 500;
  }

  /* Component cards */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.9rem;
  }
  .card {
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    background: var(--surface, transparent);
  }
  .card header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin: 0 0 0.3rem;
  }
  .card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
  }
  .card p {
    font-size: 0.86rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }
  .dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-ok { background: hsl(150 22% 38%); box-shadow: 0 0 0 3px hsl(150 22% 38% / 0.18); }
  .muted-fine {
    margin-top: 1.1rem;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem 1rem;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    padding: 1.4rem 0;
  }
  .stats > div { display: flex; flex-direction: column; gap: 0.15rem; }
  .num {
    font-family: var(--font-serif, ui-serif, Georgia, serif);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .num i { font-style: normal; font-size: 0.6em; color: var(--muted); }
  .label {
    font-size: 0.76rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  /* Incidents */
  .incidents { list-style: none; padding: 0; margin: 0; }
  .incidents li {
    border-left: 2px solid var(--hairline);
    padding: 0.2rem 0 1rem 1rem;
    margin: 0 0 1rem;
  }
  .incidents h3 {
    font-size: 1.04rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: var(--text);
  }
  .meta {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0 0 0.4rem;
  }
  .badge {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.05rem 0.5rem;
    border-radius: 999px;
    font-size: 0.66rem;
    border: 1px solid currentColor;
  }
  .badge-resolved      { color: hsl(150 22% 32%); }
  .badge-monitoring    { color: hsl(150 22% 32%); }
  .badge-investigating { color: hsl(36 60% 32%); }
  .badge-identified    { color: hsl(0 50% 38%); }

  .muted   { color: var(--muted); }
</style>
