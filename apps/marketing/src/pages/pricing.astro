---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

// Pricing source of truth. When you change a number here, mirror it
// in the Stripe billing config (apps/billing/plans.ts when that lands).
const tiers = [
  {
    id: 'free',
    name: 'Free',
    price: '$0',
    period: 'forever',
    blurb: 'For solo developers and OSS projects. Self-host, or use our hosted cloud — same gateway either way.',
    cta:   { label: 'Start free', href: 'https://app.aegis.dev/signup' },
    featured: false,
    quotas: [
      '1 organization, 5 agents',
      '1,000 tool-call checks / month',
      '7-day audit retention',
      '1 seat',
    ],
    features: [
      'Full detector chain (rules → ML → LLM-judge)',
      'Policy DSL + AI-generated bundles',
      'Cryptographic audit (Merkle log)',
      'Community Slack',
    ],
  },
  {
    id: 'pro',
    name: 'Pro',
    price: '$19',
    period: '/month',
    annualPrice: '$190 / yr (save 17%)',
    blurb: 'For startups and small product teams ready to gate production agents.',
    cta:   { label: 'Upgrade to Pro', href: 'https://app.aegis.dev/billing?plan=pro' },
    featured: true,
    quotas: [
      '5 organizations, 100 agents',
      '100,000 checks / month',
      '30-day audit retention',
      '3 seats',
    ],
    features: [
      'Everything in Free, plus:',
      'SCIM 2.0 + OIDC SSO',
      'Multi-agent collusion detector',
      'Workflow-aware policy generator',
      'Custom scan rules',
      'Email support, 1 business-day SLA',
    ],
  },
  {
    id: 'team',
    name: 'Team',
    price: '$99',
    period: '/month',
    annualPrice: '$990 / yr (save 17%)',
    blurb: 'For mid-market teams ready to bring AEGIS into compliance reviews.',
    cta:   { label: 'Upgrade to Team', href: 'https://app.aegis.dev/billing?plan=team' },
    featured: false,
    quotas: [
      'Unlimited orgs / agents',
      '1,000,000 checks / month',
      '90-day audit retention',
      '10 seats',
    ],
    features: [
      'Everything in Pro, plus:',
      'SAML 2.0 + ADFS / Shibboleth',
      'Witness cosignature on transparency log',
      'PI corpus + coverage report',
      'Policy effectiveness scoring',
      'Priority Slack channel',
    ],
  },
  {
    id: 'enterprise',
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    blurb: 'For regulated industries — self-hosted, BYOC, or on-prem with airgap.',
    cta:   { label: 'Contact sales', href: 'mailto:sales@aegis.dev' },
    featured: false,
    quotas: [
      'Unlimited everything',
      'Custom retention (forever available)',
      'Unlimited seats',
      'BYOC / on-prem deploy',
    ],
    features: [
      'Everything in Team, plus:',
      'SOC 2 Type II report',
      '99.9% SLA, 24/7 PagerDuty',
      'Custom detectors + on-call engineering',
      'Dedicated Slack + quarterly review',
      'MSA + DPA + BAA available',
    ],
  },
];
---

<Layout
  title="Pricing — AEGIS"
  description="AEGIS pricing — Free (1k requests/mo), Pro ($99/mo, 100k requests, SCIM SSO), Team ($499/mo, 1M requests, SAML), Enterprise (BYOC, SOC 2, 24/7)."
>
  <Header current="pricing" />

  <main>
    <section class="head">
      <div class="container container-narrow">
        <p class="eyebrow">Pricing</p>
        <h1>Pay for usage, not seats.</h1>
        <p class="lede">
          Every plan includes the same detector chain and audit
          guarantees. You scale by request volume + IdP requirements,
          not by how many engineers touch the cockpit.
        </p>
      </div>
    </section>

    <section class="tiers">
      <div class="container">
        <div class="tier-grid">
          {tiers.map(t => (
            <article class={`tier ${t.featured ? 'featured' : ''}`}>
              {t.featured && <div class="badge">Most popular</div>}
              <header>
                <h2>{t.name}</h2>
                <div class="price">
                  <span class="amount">{t.price}</span>
                  <span class="period">{t.period}</span>
                </div>
                {t.annualPrice && <p class="annual">{t.annualPrice}</p>}
                <p class="blurb">{t.blurb}</p>
              </header>
              <ul class="quotas">
                {t.quotas.map(q => <li class="quota">{q}</li>)}
              </ul>
              <ul class="features">
                {t.features.map(f => <li>{f}</li>)}
              </ul>
              <a class={t.featured ? 'btn' : 'btn-secondary'} href={t.cta.href}>{t.cta.label}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="faq">
      <div class="container container-narrow">
        <h2>Pricing FAQ</h2>

        <details>
          <summary>What counts as a "check"?</summary>
          <p>One POST to <code>/api/v1/check</code> or one LLM call
            routed through the egress proxy. Tool-call traces ingested
            for audit but NOT subject to a policy decision (e.g.
            historical replay) do not count.</p>
        </details>

        <details>
          <summary>What happens at the cap?</summary>
          <p>On Free, requests over 1,000/month return a 429 with a
            soft window — your agent retries the next month at zero
            disruption. On paid plans, overages are billed per
            10,000-check block ($1 on Pro, $0.50 on Team) — no
            request is ever dropped on a paid plan.</p>
        </details>

        <details>
          <summary>Can I self-host instead?</summary>
          <p>Yes — AEGIS is MIT-licensed.
            <code>docker compose up -d</code> from the
            <a href="https://github.com/Justin0504/Aegis" rel="noopener">GitHub repo</a>
            gives you the same gateway. Hosted SaaS is for teams who
            don't want to operate it.</p>
        </details>

        <details>
          <summary>Do I need a credit card to start?</summary>
          <p>No. Free tier requires only email verification. Upgrading
            to Pro is the first time we ask for a payment method.</p>
        </details>

        <details>
          <summary>Is there a startup / academic discount?</summary>
          <p>Yes — 50% off Pro and Team for the first 12 months for
            YC-backed companies, USC / MIT / Berkeley labs, and any
            org with &lt; 10 employees + &lt; $1M ARR. Email
            <a href="mailto:sales@aegis.dev">sales@aegis.dev</a>.</p>
        </details>

        <details>
          <summary>How does Enterprise differ technically?</summary>
          <p>Same codebase — but you get a deployment we operate inside
            your cloud (BYOC) or on-prem in an airgapped network,
            plus dedicated engineering time. We sign DPA, BAA, and any
            customer-specific MSA your legal team requires.</p>
        </details>
      </div>
    </section>
  </main>

  <Footer />

  <style>
    .head { padding: 5rem 0 2rem; }
    .eyebrow {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      margin: 0 0 0.5rem;
    }
    .lede {
      max-width: 60ch;
      color: var(--muted);
      font-size: 1.1rem;
      margin: 1rem 0 0;
    }

    .tiers { padding: 1rem 0 4rem; }
    .tier-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.2rem;
    }
    .tier {
      position: relative;
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--hairline);
      border-radius: 12px;
      padding: 1.6rem 1.4rem 1.4rem;
    }
    .tier.featured {
      border: 1px solid var(--accent);
      background: var(--surface-2);
      transform: scale(1.02);
    }
    .badge {
      position: absolute;
      top: -0.7rem;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: var(--bg);
      font-size: 0.74rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.3rem 0.6rem;
      border-radius: 99px;
      white-space: nowrap;
    }
    .tier header h2 {
      font-family: var(--font-serif);
      font-size: 1.6rem;
      margin: 0;
    }
    .price { display: flex; align-items: baseline; gap: 0.3rem; margin: 0.5rem 0 0.2rem; }
    .price .amount { font-size: 2rem; font-weight: 600; }
    .price .period { color: var(--muted); font-size: 0.9rem; }
    .annual { color: var(--muted); font-size: 0.82rem; margin: 0; }
    .blurb { color: var(--muted); font-size: 0.92rem; margin: 0.6rem 0 1rem; min-height: 4em; }
    .quotas {
      list-style: none;
      padding: 0.9rem 0;
      margin: 0 0 1rem;
      border-top: 1px solid var(--hairline);
      border-bottom: 1px solid var(--hairline);
    }
    .quotas .quota {
      font-size: 0.9rem;
      padding: 0.18rem 0;
      color: var(--text);
    }
    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 1.2rem;
      flex: 1;
    }
    .features li {
      font-size: 0.9rem;
      padding: 0.22rem 0;
      color: var(--muted);
    }
    .features li::before {
      content: "✓ ";
      color: var(--accent-positive);
      font-weight: 700;
      margin-right: 0.1rem;
    }
    .tier .btn, .tier .btn-secondary {
      justify-content: center;
      width: 100%;
    }

    @media (max-width: 980px) {
      .tier-grid { grid-template-columns: repeat(2, 1fr); }
      .tier.featured { transform: none; }
    }
    @media (max-width: 560px) {
      .tier-grid { grid-template-columns: 1fr; }
    }

    /* FAQ */
    .faq { padding: 4rem 0; border-top: 1px solid var(--hairline); }
    .faq h2 { margin-bottom: 1.5rem; }
    .faq details {
      border-bottom: 1px solid var(--hairline);
      padding: 1rem 0;
    }
    .faq summary {
      cursor: pointer;
      font-weight: 500;
      font-size: 1.04rem;
      padding: 0.2rem 0;
    }
    .faq details[open] summary { margin-bottom: 0.6rem; }
    .faq details p { color: var(--muted); margin: 0; line-height: 1.6; }
  </style>
</Layout>
