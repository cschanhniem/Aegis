---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---
<Layout
  title="404 — page not found · AEGIS"
  description="The page you're looking for doesn't exist. Try the AEGIS homepage, pricing, or GitHub."
>
  <Header />
  <main class="container container-narrow err">
    <p class="eyebrow">404</p>
    <h1>This page <em>doesn't exist</em>.</h1>
    <p class="lede">
      The URL you typed isn't a page on aegistraces.com. Most likely it was
      moved, renamed, or you got here from a broken link somewhere.
    </p>
    <p class="lede">
      Try one of these:
    </p>
    <div class="links">
      <a href="/" class="btn">Home</a>
      <a href="/pricing" class="btn-secondary">Pricing</a>
      <a href="https://github.com/Justin0504/Aegis" class="btn-secondary" target="_blank" rel="noopener">GitHub</a>
      <a href="/docs" class="btn-secondary">Docs</a>
    </div>
    <p class="hint">
      If a link from documentation or a blog post brought you here,
      let us know at <a href="mailto:hello@aegistraces.com">hello@aegistraces.com</a>
      so we can fix it.
    </p>
  </main>
  <Footer />

  <style>
    .err { padding: 6rem 0 4rem; }
    .eyebrow {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      margin: 0 0 0.5rem;
    }
    h1 em { font-style: italic; color: var(--accent); }
    .lede {
      color: var(--muted);
      font-size: 1.08rem;
      margin: 1rem 0 0;
      max-width: 56ch;
    }
    .links {
      margin: 1.5rem 0 1rem;
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .hint {
      color: var(--muted);
      font-size: 0.92rem;
      margin: 1.4rem 0 0;
    }
  </style>
</Layout>
