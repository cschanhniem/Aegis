---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ArchFlow from '@/components/ArchFlow.astro';
import CockpitMockup from '@/components/CockpitMockup.astro';
import LogoWall from '@/components/LogoWall.astro';
import Screenshot from '@/components/Screenshot.astro';
import Icon from '@/components/Icon.astro';

// Flip to false once real screenshots are dropped in /public/screenshots/.
const USE_PLACEHOLDERS = true;
---
<Layout
  title="AEGIS — runtime safety for AI agents"
  description="Stop hallucinated tool calls before they hit production. Open-source agent firewall — zero code change, cryptographic audit, multi-tenant, SOC 2 framework. MIT licensed."
>
  <Header current="home" />

  <main>
    <!-- ── HERO ─────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-text">
            <p class="eyebrow">Open-source · MIT · v0.1.0</p>
            <h1>The runtime <em>safety layer</em> for AI agents.</h1>
            <p class="lede">
              Every tool call — classified, gated, audited. Zero code change.
            </p>
            <div class="hero-cta">
              <a href="/signup" class="btn">Start free</a>
              <a href="/download" class="btn-secondary">Download</a>
            </div>
            <p class="hero-trust">
              MIT licensed · self-host or hosted · no credit card
            </p>
          </div>
          <div class="hero-visual">
            <ArchFlow />
          </div>
        </div>
      </div>
    </section>

    <!-- ── LOGO WALL ─────────────────────────────────────────────── -->
    <LogoWall />

    <!-- ── COCKPIT PREVIEW ───────────────────────────────────────── -->
    <section class="cockpit-preview">
      <div class="container">
        <p class="section-eyebrow">What you see</p>
        <h2>Every tool call, in one view.</h2>
        {USE_PLACEHOLDERS ? (
          <Screenshot
            src="/screenshots/traces-overview.png"
            alt="Cockpit — traces overview with allow / pending / block decisions"
            url="cockpit.aegis.dev / acme · traces"
            placeholder
            caption="Drop a real PNG to replace this placeholder — see /public/screenshots/README.md"
          />
        ) : (
          <Screenshot
            src="/screenshots/traces-overview.png"
            alt="Cockpit — traces overview with allow / pending / block decisions"
            url="cockpit.aegis.dev / acme · traces"
          />
        )}
        <noscript><CockpitMockup /></noscript>
      </div>
    </section>

    <!-- ── PRODUCT HIGHLIGHTS ─────────────────────────────────────── -->
    <section class="highlights">
      <div class="container">
        <p class="section-eyebrow">End-to-end</p>
        <h2>From repo scan to runtime block — one platform.</h2>

        <div class="hl-grid">
          <a class="hl" href="/features/scanner">
            <Icon name="scan-search" size={28} class="hl-icon" />
            <h3>Scan</h3>
            <p>Tree-sitter AST across Python / JS / TS. Workflow graph extracted from LangGraph, CrewAI, AutoGen, Mastra.</p>
            <span class="hl-cta">Scanner →</span>
          </a>

          <a class="hl" href="/features/policy-generator">
            <Icon name="wand-sparkles" size={28} class="hl-icon" />
            <h3>Generate</h3>
            <p>One paragraph + your tool inventory. Grammar-constrained policy bundle out, AJV-self-tested.</p>
            <span class="hl-cta">Generator →</span>
          </a>

          <a class="hl" href="/features/predeploy">
            <Icon name="shield-check" size={28} class="hl-icon" />
            <h3>Gate</h3>
            <p>CI fails on secret leaks, unsafe tool config, policy gaps, PI corpus regression. SARIF output.</p>
            <span class="hl-cta">Pre-deploy →</span>
          </a>

          <a class="hl" href="/features/customize">
            <Icon name="sliders" size={28} class="hl-icon" />
            <h3>Customize</h3>
            <p>YAML rules, TypeScript detectors, JSON DSL policies, tuned risk weights — extend without forking.</p>
            <span class="hl-cta">Customize →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ── ZERO CODE CHANGE ────────────────────────────────────────── -->
    <section class="zero-code">
      <div class="container">
        <p class="section-eyebrow">5-minute integration</p>
        <h2>Two env vars. No SDK rewrite.</h2>

        <div class="snippet-grid">
          <div class="snippet">
            <div class="snippet-label">Before</div>
            <pre><code>{`import openai
client = openai.OpenAI(
  api_key="sk-xxxx"
)`}</code></pre>
          </div>
          <div class="snippet">
            <div class="snippet-label">After (env only)</div>
            <pre><code><span class="hl">{`OPENAI_BASE_URL=https://gateway.aegis.dev/openai/v1
AEGIS_API_KEY=aeg_xxx`}</span>

# code unchanged</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- ── COMPARISON ────────────────────────────────────────────── -->
    <section class="vs">
      <div class="container">
        <p class="section-eyebrow">vs. the category</p>
        <h2>What others don't ship.</h2>
        <div class="vs-scroll">
          <table>
            <thead>
              <tr><th>Capability</th><th>AEGIS</th><th>Others</th></tr>
            </thead>
            <tbody>
              <tr><th scope="row">Cryptographic audit (Merkle + witness)</th><td class="y">RFC 6962, built-in</td><td class="n">none</td></tr>
              <tr><th scope="row">Sequence-aware anomaly</th><td class="y">n-gram LM, per-agent</td><td class="n">single-call only</td></tr>
              <tr><th scope="row">Multi-agent collusion</th><td class="y">burst / relay / cycle</td><td class="n">single-agent only</td></tr>
              <tr><th scope="row">Workflow → per-node policy</th><td class="y">5 frameworks</td><td class="n">none</td></tr>
              <tr><th scope="row">Counterfactual explainer</th><td class="y">verified by re-validation</td><td class="p">partial</td></tr>
              <tr><th scope="row">AST scan rules</th><td class="y">tree-sitter + YAML</td><td class="p">regex only</td></tr>
              <tr><th scope="row">GenAI OTel semconv</th><td class="y">full</td><td class="p">proprietary</td></tr>
              <tr><th scope="row">SCIM + SAML + OIDC</th><td class="y">all three</td><td class="p">one or the other</td></tr>
              <tr><th scope="row">Policy effectiveness scoring</th><td class="y">P/R/F1 + retire signal</td><td class="n">none</td></tr>
              <tr><th scope="row">License</th><td class="y">MIT</td><td class="n">closed</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── CTA STRIP ─────────────────────────────────────────────── -->
    <section class="cta-strip">
      <div class="container">
        <h2>Block your first hallucinated tool call this afternoon.</h2>
        <div class="cta-buttons">
          <a href="/signup" class="btn">Start free</a>
          <a href="/download" class="btn-secondary">Download</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <style>
    /* ── Hero ─────────────────────────────────────────────────────── */
    .hero { padding: 4rem 0 3rem; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 3rem;
      align-items: center;
    }
    .eyebrow {
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 0.5rem;
      font-weight: 500;
    }
    .hero h1 {
      font-size: clamp(2.4rem, 5vw, 3.6rem);
      line-height: 1.05;
      margin: 0.4rem 0 1rem;
    }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero .lede {
      font-size: 1.15rem;
      color: var(--muted);
      margin: 1rem 0 1.8rem;
      max-width: 38ch;
    }
    .hero-cta { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .hero-trust { color: var(--muted); font-size: 0.82rem; margin: 1rem 0 0; }

    @media (max-width: 880px) {
      .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
      .hero-visual { order: -1; }
    }

    /* ── section common ───────────────────────────────────────────── */
    .section-eyebrow {
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 0.4rem;
      font-weight: 500;
    }
    main h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.7rem, 2.6vw, 2.2rem);
      line-height: 1.15;
      margin: 0 0 1.8rem;
      max-width: 22ch;
    }

    /* ── Cockpit preview ──────────────────────────────────────────── */
    .cockpit-preview { padding: 3rem 0; border-top: 1px solid var(--hairline); background: var(--surface); }

    /* ── Highlights ────────────────────────────────────────────── */
    .highlights { padding: 4rem 0; border-top: 1px solid var(--hairline); }
    .hl-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }
    .hl {
      display: block;
      background: var(--surface);
      border: 1px solid var(--hairline);
      border-radius: 12px;
      padding: 1.4rem 1.2rem 1.2rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s, transform 0.05s;
    }
    .hl:hover { border-color: var(--accent); }
    .hl:active { transform: translateY(1px); }
    .hl-icon { width: 32px; height: 32px; color: var(--accent); margin-bottom: 0.6rem; }
    .hl h3 { font-family: var(--font-serif); font-size: 1.2rem; margin: 0 0 0.4rem; }
    .hl p { color: var(--muted); font-size: 0.9rem; margin: 0 0 0.8rem; line-height: 1.5; }
    .hl-cta { font-weight: 500; font-size: 0.86rem; color: var(--accent); }

    /* ── Zero code ──────────────────────────────────────────────── */
    .zero-code { padding: 4rem 0; border-top: 1px solid var(--hairline); background: var(--surface); }
    .snippet-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .snippet {
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 10px;
      padding: 1rem 1.1rem;
    }
    .snippet pre { background: transparent; border: none; padding: 0; margin: 0; }
    .snippet-label {
      font-size: 0.74rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }
    .hl { background: var(--accent); color: var(--bg); padding: 0 2px; }
    @media (max-width: 720px) {
      .snippet-grid { grid-template-columns: 1fr; }
    }

    /* ── vs table ─────────────────────────────────────────────── */
    .vs { padding: 4rem 0; border-top: 1px solid var(--hairline); }
    .vs-scroll { overflow-x: auto; }
    .vs table {
      width: 100%;
      min-width: 620px;
      border-collapse: collapse;
    }
    .vs thead th {
      text-align: left;
      font-weight: 600;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0.6rem 0.9rem;
      border-bottom: 1px solid var(--hairline);
    }
    .vs tbody th[scope="row"] {
      text-align: left;
      font-weight: 500;
      padding: 0.65rem 0.9rem;
      width: 50%;
    }
    .vs tbody td { padding: 0.65rem 0.9rem; width: 25%; vertical-align: top; }
    .vs tbody tr + tr { border-top: 1px solid var(--hairline); }
    .vs tbody td.y { color: var(--text); font-weight: 500; }
    .vs tbody td.y::before { content: "✓ "; color: var(--accent-positive); font-weight: 700; }
    .vs tbody td.p { color: var(--muted); }
    .vs tbody td.p::before { content: "◐ "; color: var(--accent-warn); font-weight: 700; }
    .vs tbody td.n { color: var(--muted); }
    .vs tbody td.n::before { content: "✗ "; color: var(--accent-error); font-weight: 700; }

    /* ── CTA strip ─────────────────────────────────────────────── */
    .cta-strip { padding: 4rem 0; border-top: 1px solid var(--hairline); background: var(--surface); }
    .cta-strip h2 { max-width: 24ch; }
    .cta-buttons { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  </style>
</Layout>
