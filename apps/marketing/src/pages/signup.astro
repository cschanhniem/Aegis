---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---
<Layout
  title="Sign up — AEGIS"
  description="Get early access to the AEGIS hosted gateway. Free tier — 1k requests/month, 7-day audit retention, no credit card required."
>
  <Header />
  <main>
    <section class="signup">
      <div class="container container-narrow">
        <p class="eyebrow">Get started</p>
        <h1>Start free in <em>5 minutes</em>.</h1>
        <p class="lede">
          The hosted gateway is opening up to early-access tenants now.
          Drop your email and you'll get a working API key + a one-line
          integration snippet in your inbox the same day.
        </p>

        <form class="form" method="POST" action="mailto:hello@aegis.dev" enctype="text/plain">
          <label>
            <span>Work email</span>
            <input type="email" name="email" placeholder="you@company.com" required autocomplete="email" />
          </label>

          <label>
            <span>What are you building?</span>
            <textarea name="use_case" rows="3" placeholder="One sentence is fine — e.g. 'customer support copilot with shell + email tools'"></textarea>
          </label>

          <label class="row">
            <input type="checkbox" name="terms" required />
            <span>I'll be reasonable — no scraping, no abuse, no PII you don't have rights to. <a href="/terms">Terms</a> · <a href="/privacy">Privacy</a></span>
          </label>

          <button class="btn" type="submit">Send & open mail client →</button>
        </form>

        <p class="alt">
          Already have an account?
          <a href="/login">Sign in</a> ·
          Prefer self-host?
          <a href="/download">Download the desktop bundle</a>
        </p>
      </div>
    </section>

    <section class="what">
      <div class="container container-narrow">
        <h2>What lands in your inbox</h2>
        <ol>
          <li><strong>API key</strong> — <code>aeg_xxx</code> scoped to your org, ready to drop into <code>AEGIS_API_KEY</code>.</li>
          <li><strong>Integration snippet</strong> — one env-var change against your existing OpenAI / Anthropic / LangChain SDK, no code rewrite.</li>
          <li><strong>Cockpit URL</strong> — your dashboard with traces, policies, anomalies, audit log.</li>
          <li><strong>Calendar link</strong> — optional 30-min onboarding call if you want help wiring it up.</li>
        </ol>

        <h2>Free tier limits</h2>
        <ul>
          <li>1,000 tool-call checks per month</li>
          <li>7-day audit retention</li>
          <li>1 organization, 5 agents, 1 seat</li>
          <li>Full detector chain (rules → ML → LLM-judge)</li>
          <li>Cryptographic audit (Merkle log)</li>
          <li>Community Slack</li>
        </ul>
        <p class="muted small">
          Pro / Team / Enterprise tiers are documented on
          <a href="/pricing">/pricing</a>. Self-host has no quotas — see
          <a href="/download">/download</a>.
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <style>
    .signup { padding: 5rem 0 2rem; }
    .eyebrow { font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin: 0 0 0.5rem; }
    h1 em { font-style: italic; color: var(--accent); }
    .lede { color: var(--muted); font-size: 1.1rem; margin: 1rem 0 2rem; max-width: 56ch; }

    .form { display: flex; flex-direction: column; gap: 1rem; max-width: 500px; }
    .form label { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.92rem; }
    .form label span { color: var(--muted); font-weight: 500; }
    .form input[type="email"], .form textarea {
      font-family: inherit;
      font-size: 0.96rem;
      padding: 0.65rem 0.8rem;
      border: 1px solid var(--hairline-strong);
      border-radius: 6px;
      background: var(--surface);
      color: var(--text);
    }
    .form input[type="email"]:focus, .form textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
    .form label.row { flex-direction: row; align-items: flex-start; gap: 0.5rem; font-size: 0.86rem; color: var(--muted); }
    .form label.row input { margin-top: 0.18rem; }
    .form .btn { align-self: flex-start; padding: 0.8rem 1.3rem; }
    .alt { color: var(--muted); font-size: 0.9rem; margin-top: 1.6rem; }

    .what { padding: 3rem 0 5rem; border-top: 1px solid var(--hairline); }
    .what h2 { font-family: var(--font-serif); font-size: 1.4rem; margin: 0 0 0.8rem; }
    .what h2:not(:first-child) { margin-top: 2rem; }
    .what ol, .what ul { padding-left: 1.2rem; color: var(--text); }
    .what li { margin: 0.4rem 0; }
    .what li strong { font-weight: 600; }
    .what code { background: var(--surface); padding: 0 4px; border-radius: 3px; }
    .muted { color: var(--muted); }
    .small { font-size: 0.88rem; }
  </style>
</Layout>
