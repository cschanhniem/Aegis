---

<section class="cs">
  <div class="container">
    <p class="cs-eyebrow">Compatible with the stacks teams already ship</p>

    <ul class="cs-grid">
      {LOGOS.map(l => (
        <li class="cs-cell">
          {/* fill-rule="evenodd" so brand marks with interior cutouts —
             Anthropic A slash, Coinbase ring, OpenAI petals — render
             with the right negative space at 20-px size. */}
          <svg viewBox="0 0 24 24" fill={l.color} fill-rule="evenodd" aria-hidden="true"><path d={l.path} /></svg>
          <span>{l.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .cs {
    padding: 4rem 0 4.5rem;
    border-top: 1px solid var(--hairline);
    background: var(--surface);
  }
  .cs-eyebrow {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-align: center;
    margin: 0 0 2.2rem;
    font-weight: 500;
  }
  .cs-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0;
    border-top: 1px solid var(--hairline);
    border-left: 1px solid var(--hairline);
  }
  .cs-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.4rem 0.6rem;
    border-right: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .cs-cell:hover {
    background: var(--bg);
    color: var(--text);
  }
  .cs-cell svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .cs-fine {
    text-align: center;
    color: var(--muted);
    font-size: 0.78rem;
    margin: 2rem 0 0;
  }

  @media (max-width: 1080px) { .cs-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 640px)  { .cs-grid { grid-template-columns: repeat(2, 1fr); } .cs-cell { padding: 1.1rem 0.4rem; font-size: 0.85rem; } }
</style>
