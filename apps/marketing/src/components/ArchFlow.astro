---
// Architectural flow — the headline visual that shows what AEGIS
// actually IS in one glance: agent → gateway (with 4 detector lanes)
// → tool. Audit log + cockpit branch out the back.
// Pure inline SVG so it loads instant, scales, restyles with CSS.
---
<figure class="arch-fig" aria-label="AEGIS architecture flow">
  <svg viewBox="0 0 760 280" preserveAspectRatio="xMidYMid meet" role="img">
    <defs>
      <linearGradient id="gw" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="hsl(36 55% 32%)"/>
        <stop offset="1" stop-color="hsl(36 35% 22%)"/>
      </linearGradient>
      <marker id="arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M0 0L10 5L0 10z" fill="currentColor"/>
      </marker>
    </defs>

    <!-- Agent node -->
    <g transform="translate(20 110)">
      <rect width="120" height="60" rx="8" fill="var(--bg)" stroke="var(--hairline-strong)"/>
      <text x="60" y="28" text-anchor="middle" font-size="13" font-weight="600" fill="var(--text)" font-family="var(--font-serif)">your agent</text>
      <text x="60" y="46" text-anchor="middle" font-size="10" fill="var(--muted)">Anthropic / OpenAI / LangChain</text>
    </g>

    <!-- Inbound arrow -->
    <path d="M148 140 L 210 140" stroke="var(--muted)" stroke-width="1.5" fill="none" marker-end="url(#arr)" style="color:var(--muted)"/>

    <!-- Gateway block (with 4 detector lanes) -->
    <g transform="translate(220 60)">
      <rect width="320" height="160" rx="10" fill="url(#gw)" />
      <text x="160" y="26" text-anchor="middle" font-size="13" font-weight="600" fill="var(--bg)" font-family="var(--font-serif)" letter-spacing="0.04em">AEGIS GATEWAY</text>

      <!-- 4 detector chips -->
      <g font-family="var(--font-mono)" font-size="10">
        <rect x="20"  y="48"  width="130" height="36" rx="6" fill="hsl(36 25% 90%)" opacity="0.92"/>
        <text x="85" y="65" text-anchor="middle" fill="hsl(36 50% 20%)" font-weight="600">L1 · rules</text>
        <text x="85" y="78" text-anchor="middle" fill="hsl(36 30% 35%)" font-size="9">SQL / FS / cmd inj.</text>

        <rect x="170" y="48"  width="130" height="36" rx="6" fill="hsl(36 25% 90%)" opacity="0.92"/>
        <text x="235" y="65" text-anchor="middle" fill="hsl(36 50% 20%)" font-weight="600">L2 · ML</text>
        <text x="235" y="78" text-anchor="middle" fill="hsl(36 30% 35%)" font-size="9">Mahalanobis / IF / HST</text>

        <rect x="20"  y="96" width="130" height="36" rx="6" fill="hsl(36 25% 90%)" opacity="0.92"/>
        <text x="85" y="113" text-anchor="middle" fill="hsl(36 50% 20%)" font-weight="600">L3 · LLM judge</text>
        <text x="85" y="126" text-anchor="middle" fill="hsl(36 30% 35%)" font-size="9">borderline calls</text>

        <rect x="170" y="96" width="130" height="36" rx="6" fill="hsl(36 25% 90%)" opacity="0.92"/>
        <text x="235" y="113" text-anchor="middle" fill="hsl(36 50% 20%)" font-weight="600">DSL · policy</text>
        <text x="235" y="126" text-anchor="middle" fill="hsl(36 30% 35%)" font-size="9">per-tenant overlay</text>
      </g>

      <!-- decision label -->
      <text x="160" y="152" text-anchor="middle" font-size="11" font-family="var(--font-mono)" fill="var(--bg)" opacity="0.85">decision: allow · pending · block</text>
    </g>

    <!-- Outbound arrow -->
    <path d="M548 140 L 610 140" stroke="var(--muted)" stroke-width="1.5" fill="none" marker-end="url(#arr)" style="color:var(--muted)"/>

    <!-- Tool -->
    <g transform="translate(620 110)">
      <rect width="120" height="60" rx="8" fill="var(--bg)" stroke="var(--hairline-strong)"/>
      <text x="60" y="28" text-anchor="middle" font-size="13" font-weight="600" fill="var(--text)" font-family="var(--font-serif)">tool</text>
      <text x="60" y="46" text-anchor="middle" font-size="10" fill="var(--muted)">DB / shell / email / HTTP</text>
    </g>

    <!-- Audit branch (downward) -->
    <path d="M380 220 Q 380 248 410 250 L 540 250" stroke="hsl(140 30% 40%)" stroke-width="1.2" fill="none" stroke-dasharray="3 3"/>
    <g transform="translate(540 234)">
      <rect width="200" height="34" rx="6" fill="hsl(140 30% 92%)" stroke="hsl(140 30% 70%)"/>
      <text x="14"  y="22" font-size="11" font-weight="600" fill="hsl(140 40% 24%)">audit + transparency log</text>
      <text x="184" y="22" text-anchor="end" font-size="10" fill="hsl(140 40% 35%)" font-family="var(--font-mono)">RFC 6962</text>
    </g>

    <!-- Cockpit branch (upward) -->
    <path d="M380 60 Q 380 32 410 30 L 540 30" stroke="hsl(220 25% 50%)" stroke-width="1.2" fill="none" stroke-dasharray="3 3"/>
    <g transform="translate(540 14)">
      <rect width="200" height="34" rx="6" fill="hsl(220 25% 94%)" stroke="hsl(220 25% 72%)"/>
      <text x="14"  y="22" font-size="11" font-weight="600" fill="hsl(220 35% 28%)">cockpit dashboard</text>
      <text x="184" y="22" text-anchor="end" font-size="10" fill="hsl(220 35% 40%)" font-family="var(--font-mono)">live</text>
    </g>
  </svg>
</figure>

<style>
  .arch-fig {
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 1.4rem 1rem;
  }
  .arch-fig svg { width: 100%; height: auto; display: block; }
</style>
