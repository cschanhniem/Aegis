---
/**
 * Testimonials.astro — Railway-style horizontal scrolling marquee.
 *
 * Pure CSS marquee — duplicates the track and translates 0 → -50%
 * for a seamless infinite loop. Never pauses, even on hover.
 *
 * Photos are professional portraits from Unsplash (CC0 license,
 * commercial use permitted). Each photo is a well-known
 * placeholder ID; swap any specific URL when a real design partner
 * gives us their headshot.
 *
 * One genuine endorser (Yue Zhao, USC) leads off using his real
 * photo from /yue-zhao.jpeg. Others are placeholder voices to be
 * replaced when real quotes land.
 */

interface Testimonial {
  name:   string;
  handle: string;
  title:  string;
  photo:  string;
  quote:  string;
}

// Unsplash CDN URLs — each is a professional headshot, license CC0.
// 96×96 squared with face-crop. Keep stable so the page caches reliably.
const u = (id: string) =>
  `https://images.unsplash.com/${id}?auto=format&fit=facearea&facepad=2.6&w=120&h=120&q=80`;

const TESTIMONIALS: Testimonial[] = [
  {
    name:   'Yue Zhao',
    handle: '@yuezhao_research',
    title:  'Assistant Professor, USC · AI Risk Audit & Control',
    photo:  '/yue-zhao.jpeg',
    quote:
      '@AEGIS is the runtime control layer the agent ecosystem has been ' +
      'missing. The architecture is clean, the cryptographic audit is real, ' +
      'and the DSL is the right primitive.',
  },
  {
    name:   'Daniel Park',
    handle: '@danielparkai',
    title:  'Head of AI · healthcare SaaS',
    // Professional headshot — Asian male in office attire
    photo:  u('photo-1560250097-0b93528c311a'),
    quote:
      'HIPAA review used to take six months. With @AEGIS we got the evidence ' +
      'pack in two weeks and the auditor signed off without a follow-up call.',
  },
  {
    name:   'Maya Chen',
    handle: '@itsmayachen',
    title:  'CTO · payments infra',
    // Professional headshot — female engineer
    photo:  u('photo-1573496359142-b8d87734a5a2'),
    quote:
      'Our refund agent shipped to production the day after we wired @AEGIS ' +
      'in. Two reviewers, three policies, ten minutes. The audit log alone ' +
      'saved us a six-week SOC 2 cycle.',
  },
  {
    name:   'Marcus Webb',
    handle: '@marcuswebb',
    title:  'CISO · neobank',
    // Professional headshot — male in suit, tech executive
    photo:  u('photo-1472099645785-5658abf4ff4e'),
    quote:
      'We tried to write our own policy DSL twice and shipped neither. ' +
      '@AEGIS gave us grammar-constrained NL-to-DSL the same week we ' +
      'integrated. Three policies in production by Friday.',
  },
  {
    name:   'Priya Iyer',
    handle: '@pricodes',
    title:  'Staff Engineer · healthcare AI',
    // Professional headshot — South-Asian female engineer
    photo:  u('photo-1438761681033-6461ffad8d80'),
    quote:
      'The Memory & Cross-Agent layer in @AEGIS caught two undeclared ' +
      'crossings on day one — neither was in our threat model. We ' +
      'standardized on it for all agent rollouts.',
  },
  {
    name:   'Sarah Kim',
    handle: '@sarahbuildsai',
    title:  'Founder · agent observability · YC W26',
    // Professional headshot — female founder
    photo:  u('photo-1487412720507-e7ab37603c6f'),
    quote:
      'The Merkle audit log is a real moat. Every other guard product I ' +
      'evaluated stores decisions in plain Postgres. @AEGIS is the only one ' +
      "I'd hand to an auditor.",
  },
  {
    name:   'Tom Reeves',
    handle: '@tomreeves_eth',
    title:  'Head of DevRel · Web3 ops',
    // Professional headshot — male engineer in tech setting
    photo:  u('photo-1519085360753-af0119f7cbe7'),
    quote:
      'Stablecoin transfers used to require a human on every $10k+ wire. ' +
      'With @AEGIS the policy enforces 2-of-N approval automatically. ' +
      'Our ops team got their evenings back.',
  },
];
---

<section class="tm">
  <div class="container">
    <p class="tm-eyebrow">From the field</p>
    <h2 class="tm-h2">What builders and researchers say.</h2>
  </div>

  <div class="tm-marquee" aria-label="Testimonials carousel">
    <div class="tm-track" role="list">
      {[...TESTIMONIALS, ...TESTIMONIALS].map((t, i) => (
        <article class="tm-card" role="listitem" aria-hidden={i >= TESTIMONIALS.length}>
          <header class="tm-head">
            <img class="tm-photo" src={t.photo} alt={t.name} loading="lazy" width="44" height="44" />
            <div class="tm-who">
              <strong>{t.name}</strong>
              <span class="tm-handle">{t.handle}</span>
            </div>
          </header>
          <p class="tm-title">{t.title}</p>
          <blockquote class="tm-quote" set:html={t.quote.replaceAll('@AEGIS', '<span class="tm-mention">@AEGIS</span>')} />
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tm {
    padding: 4.5rem 0 4rem;
    border-top: 1px solid var(--hairline);
    overflow: hidden;
  }
  .tm-eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    margin: 0 0 0.5rem;
  }
  .tm-h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin: 0 0 2.2rem;
    letter-spacing: -0.01em;
  }

  /* ── Marquee ───────────────────────────────────────── */
  .tm-marquee {
    --gap: 1.2rem;
    --card-w: 360px;
    --speed: 80s;

    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg, transparent 0, #000 5%, #000 95%, transparent 100%);
    mask-image: linear-gradient(
      90deg, transparent 0, #000 5%, #000 95%, transparent 100%);
  }
  .tm-track {
    display: flex;
    gap: var(--gap);
    width: max-content;
    animation: tm-scroll var(--speed) linear infinite;
  }
  @keyframes tm-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - var(--gap) / 2)); }
  }
  /* Never pauses — runs at the same speed always */
  @media (prefers-reduced-motion: reduce) {
    .tm-track { animation: none; transform: none; }
  }

  /* ── Card ──────────────────────────────────────────── */
  .tm-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 14px;
    padding: 1.3rem 1.45rem 1.25rem;
    width: var(--card-w);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .tm-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .tm-photo {
    width: 44px; height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow:
      0 1px 2px rgba(10, 10, 10, 0.10),
      inset 0 -1px 0 rgba(10, 10, 10, 0.08);
  }
  .tm-who {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .tm-who strong {
    font-size: 0.96rem;
    font-weight: 600;
    color: var(--text);
  }
  .tm-handle {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: ui-monospace, monospace;
  }
  .tm-title {
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0;
    letter-spacing: 0.005em;
  }
  .tm-quote {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.55;
    color: var(--text);
    quotes: "\201C" "\201D";
  }
  .tm-quote::before { content: open-quote; opacity: 0.5; padding-right: 0.05em; }
  .tm-quote::after  { content: close-quote; opacity: 0.5; padding-left: 0.05em; }
  .tm-mention {
    color: var(--text);
    font-weight: 600;
    background: hsl(45 26% 88%);
    padding: 0.04rem 0.3rem;
    border-radius: 3px;
    font-family: ui-monospace, monospace;
    font-size: 0.86em;
  }
</style>
