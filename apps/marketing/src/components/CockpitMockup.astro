---
// Cockpit mockup — a stylized "what the dashboard looks like" panel.
// Browser chrome + fake stats + fake trace rows. Pure HTML/CSS, no
// external assets, no real screenshot needed. Cinematic enough to
// stand in for the actual product UI in marketing screenshots.
---
<figure class="mockup" aria-label="AEGIS cockpit dashboard preview">
  <div class="chrome">
    <span class="dot r"></span>
    <span class="dot y"></span>
    <span class="dot g"></span>
    <span class="url">cockpit.aegis.dev / acme</span>
  </div>

  <div class="dash">
    <div class="sidebar">
      <div class="nav-item active">Traces</div>
      <div class="nav-item">Policies</div>
      <div class="nav-item">Anomalies</div>
      <div class="nav-item">Approvals <span class="badge">3</span></div>
      <div class="nav-item">Audit log</div>
      <div class="nav-item">Settings</div>
    </div>

    <div class="main">
      <div class="stats">
        <div class="stat"><div class="num">14,829</div><div class="lab">tool calls / 24h</div></div>
        <div class="stat"><div class="num green">99.4%</div><div class="lab">allow rate</div></div>
        <div class="stat"><div class="num amber">82</div><div class="lab">pending review</div></div>
        <div class="stat"><div class="num red">37</div><div class="lab">blocked</div></div>
      </div>

      <div class="table-head">
        <span class="col-t">time</span>
        <span class="col-a">agent</span>
        <span class="col-tool">tool</span>
        <span class="col-d">decision</span>
        <span class="col-p">policy</span>
      </div>

      <div class="row">
        <span class="col-t">12:47:09</span>
        <span class="col-a">support-bot</span>
        <span class="col-tool">send_email</span>
        <span class="col-d"><span class="pill green">allow</span></span>
        <span class="col-p">email-allowlist</span>
      </div>
      <div class="row">
        <span class="col-t">12:47:02</span>
        <span class="col-a">orchestrator</span>
        <span class="col-tool">db_query</span>
        <span class="col-d"><span class="pill red">block</span></span>
        <span class="col-p">sql-injection</span>
      </div>
      <div class="row">
        <span class="col-t">12:46:58</span>
        <span class="col-a">crew-research</span>
        <span class="col-tool">http_post</span>
        <span class="col-d"><span class="pill amber">pending</span></span>
        <span class="col-p">anomaly · 0.83</span>
      </div>
      <div class="row">
        <span class="col-t">12:46:41</span>
        <span class="col-a">support-bot</span>
        <span class="col-tool">search_kb</span>
        <span class="col-d"><span class="pill green">allow</span></span>
        <span class="col-p">—</span>
      </div>
      <div class="row">
        <span class="col-t">12:46:30</span>
        <span class="col-a">coding-asst</span>
        <span class="col-tool">file_write</span>
        <span class="col-d"><span class="pill red">block</span></span>
        <span class="col-p">file-access</span>
      </div>
    </div>
  </div>
</figure>

<style>
  .mockup {
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 24px hsla(36, 30%, 30%, 0.08);
  }
  .chrome {
    background: hsl(36 25% 88%);
    padding: 0.5rem 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid var(--hairline);
  }
  .dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
  .dot.r { background: #ed6a5e; }
  .dot.y { background: #f4be4f; }
  .dot.g { background: #61c554; }
  .chrome .url {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: hsl(36 25% 35%);
    padding: 0.18rem 0.7rem;
    background: hsl(36 30% 94%);
    border-radius: 4px;
  }

  .dash {
    display: grid;
    grid-template-columns: 180px 1fr;
    min-height: 360px;
    background: var(--bg);
  }
  .sidebar {
    background: hsl(36 28% 94%);
    border-right: 1px solid var(--hairline);
    padding: 0.8rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .nav-item {
    font-size: 0.84rem;
    padding: 0.42rem 0.7rem;
    border-radius: 5px;
    color: hsl(36 15% 30%);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .nav-item.active {
    background: var(--bg);
    color: var(--text);
    font-weight: 500;
    border: 1px solid var(--hairline);
  }
  .badge {
    margin-left: auto;
    background: hsl(36 60% 50%);
    color: var(--bg);
    font-size: 0.7rem;
    padding: 0 0.4rem;
    border-radius: 99px;
  }

  .main { padding: 1rem 1.2rem; }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .stat {
    background: hsl(36 25% 96%);
    border: 1px solid var(--hairline);
    border-radius: 6px;
    padding: 0.6rem 0.7rem;
  }
  .num { font-family: var(--font-serif); font-size: 1.4rem; line-height: 1; }
  .num.green { color: hsl(140 40% 35%); }
  .num.amber { color: hsl(36 60% 40%); }
  .num.red   { color: hsl(0 50% 45%); }
  .lab { font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem; letter-spacing: 0.03em; text-transform: uppercase; }

  .table-head, .row {
    display: grid;
    grid-template-columns: 76px 110px 1fr 90px 1fr;
    align-items: center;
    padding: 0.42rem 0;
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }
  .table-head { color: var(--muted); font-size: 0.7rem; letter-spacing: 0.05em; text-transform: uppercase; border-bottom: 1px solid var(--hairline); }
  .row { border-bottom: 1px solid var(--hairline); }
  .row:last-child { border-bottom: 0; }
  .row .col-tool, .row .col-p { color: hsl(36 15% 30%); }

  .pill { font-size: 0.7rem; padding: 0.1rem 0.45rem; border-radius: 99px; font-family: var(--font-sans); letter-spacing: 0.03em; }
  .pill.green { background: hsl(140 30% 90%); color: hsl(140 40% 25%); }
  .pill.amber { background: hsl(36 60% 90%); color: hsl(36 60% 30%); }
  .pill.red   { background: hsl(0 30% 92%); color: hsl(0 40% 35%); }

  @media (max-width: 720px) {
    .sidebar { display: none; }
    .dash { grid-template-columns: 1fr; }
    .table-head, .row { grid-template-columns: 60px 1fr 80px; }
    .col-a, .col-p { display: none; }
  }
</style>
