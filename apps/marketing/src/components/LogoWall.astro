<style>
  .logo-wall {
    padding: 3rem 0;
    background: var(--bg);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .lw-eyebrow {
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 2rem;
    font-weight: 500;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }
  .logos {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 1.5rem 2rem;
    align-items: center;
    justify-items: center;
    max-width: 980px;
    margin: 0 auto;
  }
  .logo {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: hsl(36 16% 36%);
    text-decoration: none;
    opacity: 0.72;
    transition: opacity 0.18s, color 0.18s;
  }
  .logo:hover {
    opacity: 1;
    color: hsl(36 22% 22%);
  }
  .logo svg {
    height: 26px;
    width: 26px;
    display: block;
  }
  .logo-name {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .logos { grid-template-columns: repeat(4, 1fr); gap: 1.6rem 1.2rem; }
  }
  @media (max-width: 480px) {
    .logos { grid-template-columns: repeat(3, 1fr); }
  }
</style>
