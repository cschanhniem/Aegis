---
// Brand logos — official assets from each vendor.
//
// Sources (all permissive / public marketing assets):
//   anthropic.svg   gilbarbara/logos    (canonical monochrome mark)
//   openai.svg      gilbarbara/logos    (canonical monochrome mark)
//   vercel.svg      gilbarbara/logos    (canonical mark)
//   gemini.svg      gilbarbara/logos    (official multi-stop blue gradient)
//   huggingface.svg gilbarbara/logos    (official full-color emoji)
//   langchain.png   github.com/langchain-ai org avatar  (official mark)
//   crewai.png      github.com/crewAIInc org avatar      (official mark)
//   llamaindex.png  llamaindex.ai favicon (extracted from base64-embedded PNG)
//
// AutoGen + Mastra don't ship a public brand asset we can use, so
// they're mentioned in the eyebrow line instead of the visual row.
---
<section class="logo-wall">
  <div class="container">
    <p class="lw-eyebrow">Works with the agents you already ship — incl. LangGraph, AutoGen, Mastra</p>
    <div class="logos">
      <a class="logo" href="https://www.anthropic.com" target="_blank" rel="noopener" aria-label="Anthropic">
        <img src="/logos/anthropic.svg" alt="" width="32" height="32" />
        <span class="logo-name">Anthropic</span>
      </a>
      <a class="logo" href="https://openai.com" target="_blank" rel="noopener" aria-label="OpenAI">
        <img src="/logos/openai.svg" alt="" width="32" height="32" />
        <span class="logo-name">OpenAI</span>
      </a>
      <a class="logo" href="https://www.langchain.com" target="_blank" rel="noopener" aria-label="LangChain">
        <img src="/logos/langchain.png" alt="" width="32" height="32" />
        <span class="logo-name">LangChain</span>
      </a>
      <a class="logo" href="https://www.crewai.com" target="_blank" rel="noopener" aria-label="CrewAI">
        <img src="/logos/crewai.png" alt="" width="32" height="32" />
        <span class="logo-name">CrewAI</span>
      </a>
      <a class="logo" href="https://vercel.com/ai" target="_blank" rel="noopener" aria-label="Vercel AI SDK">
        <img src="/logos/vercel.svg" alt="" width="32" height="32" />
        <span class="logo-name">Vercel</span>
      </a>
      <a class="logo" href="https://gemini.google.com" target="_blank" rel="noopener" aria-label="Gemini">
        <img src="/logos/gemini.svg" alt="" width="32" height="32" />
        <span class="logo-name">Gemini</span>
      </a>
      <a class="logo" href="https://www.llamaindex.ai" target="_blank" rel="noopener" aria-label="LlamaIndex">
        <img src="/logos/llamaindex.png" alt="" width="32" height="32" />
        <span class="logo-name">LlamaIndex</span>
      </a>
      <a class="logo" href="https://huggingface.co" target="_blank" rel="noopener" aria-label="Hugging Face">
        <img src="/logos/huggingface.svg" alt="" width="32" height="32" />
        <span class="logo-name">Hugging Face</span>
      </a>
    </div>
  </div>
</section>

<style>
  .logo-wall {
    padding: 3rem 0;
    background: var(--bg);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .lw-eyebrow {
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 auto 2rem;
    font-weight: 500;
    max-width: 56ch;
  }
  .logos {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 1.5rem 2rem;
    align-items: center;
    justify-items: center;
    max-width: 980px;
    margin: 0 auto;
  }
  .logo {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: hsl(36 18% 30%);
    transition: transform 0.18s;
  }
  .logo:hover { transform: translateY(-2px); }
  .logo img {
    height: 32px;
    width: 32px;
    object-fit: contain;
    display: block;
  }
  .logo-name {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  @media (max-width: 980px) {
    .logos { grid-template-columns: repeat(4, 1fr); gap: 1.6rem 1.2rem; }
  }
  @media (max-width: 480px) {
    .logos { grid-template-columns: repeat(3, 1fr); }
  }
</style>
