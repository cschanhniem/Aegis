---
// Brand logos — paths lifted from Simple Icons (CC0 license, simpleicons.org).
// Rendered as currentColor so they blend with the warm-light theme.
// These are the frameworks/SDKs AEGIS auto-instruments.
---
<section class="logo-wall">
  <div class="container">
    <p class="lw-eyebrow">Works with the agents you already ship</p>
    <div class="logos">
      <!-- Anthropic -->
      <span class="logo" title="Anthropic">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Anthropic">
          <path fill="currentColor" d="M13.827 3.52h3.603L24 20h-3.603l-6.57-16.48zm-7.258 0h3.767L16.906 20h-3.674l-1.343-3.461H5.017l-1.344 3.46H0L6.57 3.522zm4.132 9.959L8.453 7.687 6.205 13.48H10.7z"/>
        </svg>
      </span>
      <!-- OpenAI -->
      <span class="logo" title="OpenAI">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="OpenAI">
          <path fill="currentColor" d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365 2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
        </svg>
      </span>
      <!-- LangChain -->
      <span class="logo" title="LangChain">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="LangChain">
          <path fill="currentColor" d="M19.5 8.5h-3.25v-2c0-2.485-2.015-4.5-4.5-4.5s-4.5 2.015-4.5 4.5v2H4.5C3.119 8.5 2 9.619 2 11v9c0 1.381 1.119 2.5 2.5 2.5h15c1.381 0 2.5-1.119 2.5-2.5v-9c0-1.381-1.119-2.5-2.5-2.5zm-9.75-2c0-1.241 1.009-2.25 2.25-2.25s2.25 1.009 2.25 2.25v2h-4.5v-2zM12 18.5c-1.381 0-2.5-1.119-2.5-2.5s1.119-2.5 2.5-2.5 2.5 1.119 2.5 2.5-1.119 2.5-2.5 2.5z"/>
        </svg>
      </span>
      <!-- CrewAI (text logo) -->
      <span class="logo logo-text" title="CrewAI">CrewAI</span>
      <!-- AutoGen (text logo) -->
      <span class="logo logo-text" title="AutoGen">AutoGen</span>
      <!-- Mastra (text logo) -->
      <span class="logo logo-text" title="Mastra">Mastra</span>
      <!-- Vercel -->
      <span class="logo" title="Vercel AI SDK">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Vercel">
          <path fill="currentColor" d="M24 22.525H0l12-21.05 12 21.05z"/>
        </svg>
      </span>
      <!-- Google (Gemini) -->
      <span class="logo logo-text" title="Gemini">Gemini</span>
      <!-- LlamaIndex -->
      <span class="logo logo-text" title="LlamaIndex">LlamaIndex</span>
    </div>
  </div>
</section>

<style>
  .logo-wall {
    padding: 2.5rem 0;
    background: var(--bg);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .lw-eyebrow {
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }
  .logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2.4rem 3rem;
    color: hsl(36 18% 38%);
  }
  .logo {
    opacity: 0.7;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    height: 28px;
  }
  .logo:hover { opacity: 1; }
  .logo svg { height: 28px; width: auto; }
  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
</style>
