---
// Screenshot frame — wraps a product PNG in browser chrome so it reads as
// "the actual product" rather than "a stock asset". If the PNG is missing,
// renders a graceful placeholder instead of breaking the build.
interface Props {
  src: string;                  // /screenshots/foo.png
  alt: string;
  url?: string;                 // chrome address bar text
  caption?: string;
  placeholder?: boolean;        // force placeholder mode (for staging)
}
const { src, alt, url = 'cockpit.aegistraces.com', caption, placeholder = false } = Astro.props;
---
<figure class="shot">
  <div class="chrome">
    <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
    <span class="url">{url}</span>
  </div>

  {placeholder ? (
    <div class="placeholder">
      <div class="ph-inner">
        <div class="ph-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
        </div>
        <p class="ph-label">{alt}</p>
        <p class="ph-hint">Drop a PNG at <code>{src}</code></p>
      </div>
    </div>
  ) : (
    <img src={src} alt={alt} loading="lazy" />
  )}

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .shot {
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 6px 28px hsla(36, 30%, 25%, 0.10);
  }
  .chrome {
    background: hsl(36 25% 88%);
    padding: 0.5rem 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid var(--hairline);
  }
  .dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
  .dot.r { background: #ed6a5e; }
  .dot.y { background: #f4be4f; }
  .dot.g { background: #61c554; }
  .chrome .url {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: hsl(36 25% 35%);
    padding: 0.18rem 0.7rem;
    background: hsl(36 30% 94%);
    border-radius: 4px;
  }

  img { display: block; width: 100%; height: auto; }

  .placeholder {
    aspect-ratio: 16 / 9;
    background:
      repeating-linear-gradient(45deg,
        hsl(36 28% 96%) 0 12px,
        hsl(36 28% 94%) 12px 24px);
    display: flex; align-items: center; justify-content: center;
  }
  .ph-inner { text-align: center; color: hsl(36 22% 40%); padding: 1rem 2rem; }
  .ph-icon { color: hsl(36 35% 45%); margin-bottom: 0.6rem; }
  .ph-label { font-family: var(--font-serif); font-size: 1.1rem; margin: 0 0 0.4rem; }
  .ph-hint { font-size: 0.84rem; color: var(--muted); margin: 0; }
  .ph-hint code { font-family: var(--font-mono); font-size: 0.78rem; }

  figcaption {
    padding: 0.7rem 1rem;
    font-size: 0.86rem;
    color: var(--muted);
    border-top: 1px solid var(--hairline);
    background: var(--bg);
  }
</style>
