---
// Editorial photo band — a wide hero strip with a single image,
// dark gradient overlay (so any overlaid text stays legible),
// and minimal chrome. Used at most ONCE per page (taste rule).
// Sourced photos must be licensed for commercial use (Unsplash/Pexels).

interface Props {
  src: string;                  // /images/foo.jpg
  alt: string;
  credit?: string;              // "Photo: Name / Unsplash"
  height?: string;              // CSS height value
  position?: string;            // object-position (e.g. "center 40%")
  overlay?: 'warm' | 'dark' | 'none';
}
const {
  src,
  alt,
  credit,
  height = 'clamp(220px, 32vw, 380px)',
  position = 'center',
  overlay = 'warm',
} = Astro.props;
---
<figure class={`band overlay-${overlay}`} style={`--band-h:${height}; --pos:${position}`}>
  <img src={src} alt={alt} loading="lazy" />
  <slot />
  {credit && <figcaption>{credit}</figcaption>}
</figure>

<style>
  .band {
    position: relative;
    margin: 0;
    width: 100%;
    height: var(--band-h);
    overflow: hidden;
    background: var(--surface);
  }
  .band img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--pos);
    display: block;
  }
  .band::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  /* warm vignette so the page palette stays cohesive */
  .overlay-warm::after {
    background:
      linear-gradient(180deg, hsla(36, 30%, 96%, 0.5) 0%, hsla(36, 30%, 96%, 0.0) 30%, hsla(36, 30%, 96%, 0.0) 70%, hsla(36, 30%, 96%, 0.85) 100%),
      linear-gradient(120deg, hsla(36, 40%, 25%, 0.3), hsla(36, 40%, 25%, 0));
  }
  .overlay-dark::after {
    background: linear-gradient(180deg, hsla(36, 30%, 12%, 0.0) 30%, hsla(36, 30%, 12%, 0.55) 100%);
  }
  .overlay-none::after { display: none; }

  .band figcaption {
    position: absolute;
    bottom: 0.5rem;
    right: 0.7rem;
    font-size: 0.68rem;
    color: hsla(36, 30%, 96%, 0.7);
    letter-spacing: 0.04em;
    font-family: var(--font-mono);
    z-index: 1;
  }

  /* overlay slot (for headline / eyebrow on top of image) */
  .band :global(.band-overlay) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 2rem;
    z-index: 1;
    color: var(--text);
  }
</style>
