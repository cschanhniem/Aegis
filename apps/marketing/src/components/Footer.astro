---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="col">
      <div class="brand">
        <span class="mark" aria-hidden="true">⌬</span>
        <span class="brand-name">AEGIS</span>
      </div>
      <p class="tagline">
        Open-source runtime safety layer for AI agents.
      </p>
    </div>
    <div class="col">
      <h4>Product</h4>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
      <a href="/security">Security</a>
      <a href="https://app.aegis.dev/signup">Start free</a>
    </div>
    <div class="col">
      <h4>Project</h4>
      <a href="https://github.com/Justin0504/Aegis" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/Justin0504/Aegis/blob/main/CHANGELOG.md" target="_blank" rel="noopener">Changelog</a>
      <a href="https://github.com/Justin0504/Aegis/blob/main/ROADMAP.md" target="_blank" rel="noopener">Roadmap</a>
      <a href="/status">Status</a>
    </div>
    <div class="col">
      <h4>Legal</h4>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
      <a href="/dpa">DPA</a>
      <a href="mailto:security@aegis.dev">security@aegis.dev</a>
    </div>
  </div>
  <div class="container colophon">
    <span>© {year} AEGIS · MIT licensed</span>
    <span class="muted">v0.1.0 — built by <a href="https://aojieyuan.com" rel="noopener">Aojie Yuan</a></span>
  </div>
  <style>
    .site-footer {
      border-top: 1px solid var(--hairline);
      padding: 3rem 0 2rem;
      margin-top: 5rem;
      background: var(--surface);
    }
    .footer-inner {
      display: grid;
      grid-template-columns: 1.5fr repeat(3, 1fr);
      gap: 2.4rem;
      padding-bottom: 2rem;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-serif);
      font-size: 1.3rem;
    }
    .mark { font-size: 1.5rem; }
    .tagline {
      color: var(--muted);
      margin: 0.4rem 0 0;
      font-size: 0.92rem;
      max-width: 26ch;
    }
    .col h4 {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 0.7rem;
      font-weight: 500;
    }
    .col a {
      display: block;
      color: var(--text);
      text-decoration: none;
      padding: 0.18rem 0;
      font-size: 0.92rem;
    }
    .col a:hover { text-decoration: underline; }
    .colophon {
      border-top: 1px solid var(--hairline);
      padding-top: 1.4rem;
      display: flex;
      justify-content: space-between;
      color: var(--muted);
      font-size: 0.82rem;
    }
    .colophon a { color: var(--text); }
    @media (max-width: 760px) {
      .footer-inner {
        grid-template-columns: 1fr 1fr;
        gap: 1.6rem;
      }
      .colophon { flex-direction: column; gap: 0.4rem; }
    }
  </style>
</footer>
