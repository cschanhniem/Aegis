# AEGIS Control Plane — environment contract.
#
# Copy to .env.local for local dev. In Vercel: paste each row into
# Project Settings → Environment Variables.

# ── Postgres (same instance the gateway uses) ──────────────────────────
# Supabase / Neon / RDS connection string. Required.
DATABASE_URL=postgres://aegis:****@localhost:5432/aegis

# ── Auth ──────────────────────────────────────────────────────────────
# next-auth secret. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:14000

# Optional SSO providers — leave blank to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────
# Test keys for dev; live keys for prod.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Product / price IDs created in the Stripe dashboard.
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_TEAM_MONTHLY=price_...
STRIPE_PRICE_ID_TEAM_ANNUAL=price_...

# ── Gateway routing ───────────────────────────────────────────────────
# Internal URL of the data-plane gateway. The control plane proxies
# /api/gw/* to this after auth + X-Org-Id injection.
GATEWAY_INTERNAL_URL=http://localhost:8080
GATEWAY_ADMIN_KEY=

# ── Cloudflare (for *.aegis.dev tenant subdomains) ───────────────────
# Token with Zone:DNS:Edit on the aegis.dev zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
TENANT_DNS_TARGET=cockpit.fly.dev   # value of the CNAME records

# ── Email (for signup verification + alerts) ─────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@aegis.dev

# ── Misc ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:14000
LOG_LEVEL=info
